"analysis.photoOptimization.title" = "Optimización de fotografías";
"analysis.photoOptimization.overall" = "General";
"analysis.photoOptimization.overallScore" = "Puntuación de fotos";
"analysis.photoOptimization.overallScoreBody" = "Esta foto tiene una base utilizable, y los mayores beneficios provienen de una luz más limpia, un encuadre más fuerte y una expresión más intencional.";
"analysis.photoOptimization.potentialScore" = "Puntuación potencial";
"analysis.photoOptimization.summary" = "Resumen";
"analysis.photoOptimization.summaryBody" = "La foto se lee lo suficientemente clara como para una primera pasada, pero los detalles de la presentación deciden si se siente premium. Priorice la visibilidad del rostro, una luz frontal suave y un recorte que mantenga los ojos fáciles de leer. Un pequeño cambio de expresión y un fondo más simple normalmente crearían la actualización más rápida.";
