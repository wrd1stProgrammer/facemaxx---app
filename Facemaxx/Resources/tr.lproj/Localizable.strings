"analysis.photoOptimization.metric.expressionWarmthDetail" = "İfade sıcaklığı, fotoğrafın rahat, açık ve yaklaşmanın kolay olup olmadığına bakar. Tarafsız bir ifade işe yarayabilir, ancak küçük bir yarım gülümseme genellikle ilk okumayı iyileştirir. Amaç doğal bir varlıktır, zorla bir sırıtış değil.";
"analysis.photoOptimization.metric.lightingQuality" = "Aydınlatma Kalitesi";
"analysis.photoOptimization.metric.lightingQualityValue" = "7.1 · Sağlam, geliştirilebilir";
"analysis.photoOptimization.metric.lightingQualityDetail" = "Aydınlatma kalitesi, yüzün ne kadar eşit şekilde aydınlatıldığını ve gölgelerin yapıya fayda mı yoksa zarar mı verdiğini ölçer. Yumuşak ön ışık genellikle cildin, gözlerin ve simetrinin daha temiz okunmasını sağlar. Profil kullanımı fotoğrafları için aşırı ışıktan veya karanlık yan gölgelerden kaçının.";
"analysis.photoOptimization.metric.composition" = "Kompozisyon";
"analysis.photoOptimization.metric.compositionValue" = "7.2 · İyi çerçevelenmiş";
"analysis.photoOptimization.metric.compositionDetail" = "Kompozisyon kırpmayı, kafa konumunu ve yüzün etrafındaki görsel dengeyi kontrol eder. Güçlü bir kompozisyon, sıkışıklık hissi yaratmadan yüzdeki dikkati korur. Başınızın etrafında yeterli boşluk bırakın ve gözleri üstteki üçte birlik kısma yakın tutun.";
"analysis.photoOptimization.metric.backgroundControl" = "Arka Plan Kontrolü";
"analysis.photoOptimization.metric.backgroundControlValue" = "6.8 · Temizlenmesi gerekiyor";
"analysis.photoOptimization.metric.backgroundControlDetail" = "Arka plan kontrolü, ayarın fotoğrafı destekleyip desteklemediğini veya yüzle rekabet edip etmediğini ölçer. Basit, temiz arka planlar tüm görüntünün daha kaliteli görünmesini sağlar. Dağınıklığı, parlak nesneleri ve başın yakınındaki garip çizgileri ortadan kaldırın.";
"analysis.photoOptimization.metric.winningMove" = "Kazandıran Hareket";
"analysis.photoOptimization.metric.winningMoveValue" = "Daha yumuşak ön ışıkla tekrar çekim";
"analysis.photoOptimization.metric.winningMoveDetail" = "Kazanan hamle, fotoğrafın bir sonraki versiyonu için en yüksek etkiye sahip tek değişikliktir. Çoğu durumda, daha iyi ışık ve daha temiz bir kırpma, sonucu yoğun düzenlemeden daha fazla iyileştirir. Net bir değişiklik yapın ve ardından bu görselle karşılaştırın.";
"analysis.photoOptimization.metric.retakeLight" = "Işığı Tekrar Çek";
"analysis.photoOptimization.metric.retakeLightValue" = "Sol önden pencere ışığı";
"analysis.photoOptimization.metric.retakeLightDetail" = "Yeniden çekim ışığı, bir sonraki sürüm için en kullanışlı aydınlatma ayarını tanımlar. Yumuşak ön yan pencere ışığı, aydınlatma sağlar ve yüzü düzleştirmeden cilt dokusunu daha temiz tutar. Telefonu sabit tutun ve güçlü ışıktan kaçının.";
"analysis.photoOptimization.metric.editCleanup" = "Temizlemeyi Düzenle";
"analysis.photoOptimization.metric.editCleanupValue" = "Arka plandaki dikkat dağıtıcı unsurları azaltın";
"analysis.photoOptimization.metric.editCleanupDetail" = "Düzenleme temizleme, görüntünün kasıtlı olduğu hissini veren küçük düzeltmelere odaklanır. Hafif bir arka plan bulanıklığı, daha sıkı kırpma veya pozlama ayarı, fotoğrafın aşırı düzenlenmiş görünmesine neden olmadan odağı iyileştirebilir. Yüz dokusunu doğal tutun.";
"analysis.photoOptimization.metric.bestAngle" = "En İyi Açı";
"analysis.photoOptimization.metric.bestAngleValue" = "Göz hizasının biraz üstünde";
"analysis.photoOptimization.metric.bestAngleDetail" = "En iyi açı, mevcut yüz yapısını daha düz hale getirme olasılığı en yüksek olan kamera konumunu tanımlar. Küçük bir yükseklik ayarı çeneyi keskinleştirebilir, çarpıklığı azaltabilir ve gözlerin okunabilir olmasını sağlayabilir. İfadeyi değiştirmeden önce aynı mesafeden birkaç kareyi yeniden çekin.";
"analysis.photoOptimization.metric.frontRead" = "Ön Okuma";
"analysis.photoOptimization.metric.frontReadValue" = "7.3 · Kararlı";
"analysis.photoOptimization.metric.frontReadDetail" = "Ön okuma, doğrudan kameraya dönük bir çekimde yüzün ne kadar dengeli göründüğünü kontrol eder. Sabit bir ön okuma, net profil fotoğrafları ve kimlik tarzı kırpmalar için kullanışlıdır. Telefonu düz tutun ve alt yüzü geren lens eğiminden kaçının.";
"analysis.photoOptimization.metric.leftRead" = "Sol Taraftan Okuma";
"analysis.photoOptimization.metric.leftReadValue" = "7.1 · Test edilmeye değer";
"analysis.photoOptimization.metric.leftReadDetail" = "Sol taraf okuması, yüzün hafif bir sola dönüşten nasıl görünebileceğini tahmin eder. Bu açı, önden görünüm düz göründüğünde yapıyı artırabilir. Dramatik bir yan profil yerine önce küçük bir dönüşü test edin.";
"analysis.photoOptimization.metric.rightRead" = "Sağ Taraftan Okuma";
"analysis.photoOptimization.metric.rightReadValue" = "7.0 · Test edilmeye değer";
"analysis.photoOptimization.metric.rightReadDetail" = "Sağ taraf okuması, hafif bir sağa dönüşte yüzün nasıl görünebileceğini tahmin eder. Daha iyi çene ve yanak tanımı veren tarafı bulmakta faydalıdır. Aynı ışık altında karşılaştırın, böylece açı tek değişken olur.";
"analysis.photoOptimization.metric.cameraHeight" = "Kamera Yüksekliği";
"analysis.photoOptimization.metric.cameraHeightValue" = "Göz seviyesi biraz yüksek";
"analysis.photoOptimization.metric.cameraHeightDetail" = "Kamera yüksekliği çene hattını, alnı ve yüzün orta kısmını çoğu insanın beklediğinden daha fazla etkiler. Göz hizası veya biraz yukarısı genellikle yüz hatlarını iyileştirirken oranların doğal kalmasını sağlar. Ana profil fotoğrafları için çene altından çekim yapmaktan kaçının.";
"analysis.photoOptimization.metric.avoidAngle" = "Kaçınılacak Açı";
"analysis.photoOptimization.metric.avoidAngleValue" = "Düşük, yakın selfie açısı";
"analysis.photoOptimization.metric.avoidAngleDetail" = "Bu, fotoğrafı zayıflatma olasılığı en yüksek olan perspektifi işaretler. Düşük yakın çekim açıları yüzün alt kısmını abartabilir, gözleri düzleştirebilir ve kırpmanın rahat görünmesini sağlayabilir. Geri çekilin, mümkünse hafif yakınlaştırmayı kullanın ve merceği daha düz tutun.";
"analysis.photoOptimization.metric.retakePlan" = "Tekrar Alma Planı";
"analysis.photoOptimization.metric.retakePlanValue" = "Aynı poz, daha net kurulum";
"analysis.photoOptimization.metric.retakePlanDetail" = "Yeniden çekim planı, analizi tekrarlanabilir bir sonraki çekime dönüştürür. Yumuşak ön ışık kullanın, kamerayı göz hizasının hemen üzerinde tutun ve küçük baş dönüşleriyle birden fazla kare çekin. Gözlerin, çene hattının ve ifadenin net bir şekilde okunduğu versiyonu seçin.";
"analysis.photoOptimization.metric.mainPhotoSuitability" = "Ana Fotoğraf Uygunluğu";
"analysis.photoOptimization.metric.mainPhotoSuitabilityValue" = "7.2 · İyi yedekleme";
"analysis.photoOptimization.metric.mainPhotoSuitabilityDetail" = "Bu, görselin ilk flört uygulaması fotoğrafı olarak çalışıp çalışmayacağını ölçer. Ana fotoğrafın hızlı bir kaydırmayı durdurmak için netliğe, sıcaklığa ve yeterli kişiliğe ihtiyacı var. Yüz net ancak enerji sessizse, bunu yedek olarak kullanın veya daha fazla varlıkla yeniden çekin.";
"analysis.photoOptimization.metric.approachability" = "Yaklaşılabilirlik";
"analysis.photoOptimization.metric.approachabilityValue" = "7.0 · Yeterince kullanıcı dostu";
"analysis.photoOptimization.metric.approachabilityDetail" = "Yaklaşılabilirlik, fotoğrafla etkileşime geçmenin kolay olup olmadığını ölçer. Daha yumuşak gözler, rahat duruş ve hafif bir gülümseme, okumayı hızla değiştirebilir. Boş, gergin veya aşırı poz veren ifadelerden kaçının.";
"analysis.photoOptimization.metric.confidenceSignal" = "Güven Sinyali";
"analysis.photoOptimization.metric.confidenceSignalValue" = "7.1 · Sakin özgüven";
"analysis.photoOptimization.metric.confidenceSignalDetail" = "Güven sinyali duruş, göz teması, çerçeveleme ve ifadeden gelir. En güçlü versiyon, sert görünmeden sakin bir his veriyor. Omuzlarınızı rahat tutun ve ekran yerine mercekten bakın.";
"analysis.photoOptimization.metric.trustSignal" = "Güven Sinyali";
"analysis.photoOptimization.metric.trustSignalValue" = "7.3 · Açık ve güvenilir";
"analysis.photoOptimization.metric.trustSignalDetail" = "Güven sinyali, görüntünün orijinal, güncel ve anlaşılması kolay olup olmadığını kontrol eder. Net aydınlatma ve filtrelenmemiş bir yüz genellikle bu puanı artırır. Fotoğrafta belirsizliğe neden olan ağır düzenlemelerden, gizli gözlerden ve ayarlardan kaçının.";
"analysis.photoOptimization.metric.conversationHook" = "Konuşma Kancası";
"analysis.photoOptimization.metric.conversationHookValue" = "6.6 · Daha güçlü bir işarete ihtiyaç var";
"analysis.photoOptimization.metric.conversationHookDetail" = "Konuşma kancası, fotoğrafın birine yorum yapması için kolay bir neden verip vermediğini ölçer. Bir ayar, etkinlik veya stil ayrıntısı profilin daha akılda kalıcı olmasını sağlayabilir. Kancayı ince tutun, böylece dikkati dağıtmak yerine yüzü destekler.";
"analysis.photoOptimization.metric.photoMix" = "Fotoğraf Karışımı";
"analysis.photoOptimization.metric.photoMixValue" = "Bağlam ve çeşitlilik ekleyin";
"analysis.photoOptimization.metric.photoMixDetail" = "Fotoğraf karışımı, bu görselin daha geniş bir profil kümesi içinde ne yapması gerektiğine bakar. Güçlü bir set genellikle bir adet net yüz fotoğrafı, bir adet tam vücut veya stil çekimi ve bir adet sosyal veya aktivite görseli içerir. Bu fotoğraf her şeyi yapmaya çalışmak yerine en iyi şekilde üstlendiği rolü yerine getirmelidir.";
"analysis.photoOptimization.metric.avoidProfile" = "Kaçınılması Gereken Profil Hatası";
"analysis.photoOptimization.metric.avoidProfileValue" = "Düşük enerjiyle liderlik etmeyin";
"analysis.photoOptimization.metric.avoidProfileDetail" = "Bu, sonuçları düşürme olasılığı en yüksek olan profil seçimini işaretler. Loş, düz, aşırı kırpılmış veya duygusal açıdan kapalı bir görüntüyle yönlendirme yapmaktan kaçının. İlk fotoğraf, yüzü ve atmosferi bir saniye içinde belirgin hale getirmelidir.";
"analysis.photoOptimization.metric.profileCrop" = "Profil Kırpma";
"analysis.photoOptimization.metric.profileCropValue" = "7.2 · Küçük resim okunabilir";
"analysis.photoOptimization.metric.profileCropDetail" = "Profil kırpma, görüntünün küçük bir daireye veya kareye küçültüldüğünde hala çalışıp çalışmadığını ölçer. Gözlerin ve yüz hatlarının küçük resim boyutunda okunabilir kalması gerekir. Yüzü çok alçak, çok küçük veya bir kenara çok yakın yerleştirmekten kaçının.";
"analysis.photoOptimization.metric.firstImpression" = "İlk İzlenim";
"analysis.photoOptimization.metric.firstImpressionValue" = "7.3 · İlk okumayı temizle";
"analysis.photoOptimization.metric.firstImpressionDetail" = "İlk izlenim, birisi ayrıntıları incelemeden önce anında görsel okumayı ölçer. Güçlü ilk izlenimler açık, kasıtlıdır ve duygusal açıdan kolaylıkla oluşturulabilir. Çerçeveyi basitleştirerek ve ifadeyi daha belirleyici hale getirerek bunu geliştirin.";
"analysis.photoOptimization.metric.feedFit" = "Feed'e Uygunluk";
"analysis.photoOptimization.metric.feedFitValue" = "7,0 · Cilaya uyar";
"analysis.photoOptimization.metric.feedFitDetail" = "Feed uyumu, görüntünün bir Instagram ızgarasına veya sosyal profile doğal olarak oturup oturmayacağını kontrol eder. Renk, kırpma, kontrast ve stilin tümü, bir bütünlük hissi verip vermeyeceğini etkiler. Profilin seçilmiş görünmesini istiyorsanız tutarlı bir aydınlatma stili kullanın.";
"analysis.photoOptimization.metric.storyThumbnail" = "Hikaye Küçük Resmi";
"analysis.photoOptimization.metric.storyThumbnailValue" = "6.9 · Daha cesur çerçeveleme gerekiyor";
"analysis.photoOptimization.metric.storyThumbnailDetail" = "Hikaye küçük resmi, görselin küçük, hızlı görüntülenen yerleşimlerde okunabilir kalıp kalmadığını ölçer. Net bir yüz, basit bir arka plan ve daha güçlü bir kontrast yardımcı olur. Fotoğraf çok ince görünüyorsa yüzün ve vücudun üst kısmının çevresini daha sıkı kırpın.";
"analysis.photoOptimization.metric.visualConsistency" = "Görsel Tutarlılık";
"analysis.photoOptimization.metric.visualConsistencyValue" = "7.1 · Çoğunlukla uyumlu";
"analysis.photoOptimization.metric.visualConsistencyDetail" = "Görsel tutarlılık, fotoğrafın renginin, ışığının ve stilinin parlak profil yönüyle ne kadar iyi eşleştiğini ölçer. Tutarlılık, profilin rastgele yerine kasıtlı olduğunu hissettirir. Bir aydınlatma modu seçin ve bunu en iyi fotoğraflarınızda tekrarlayın.";
"analysis.photoOptimization.metric.captionDirection" = "Altyazı Yönü";
"analysis.photoOptimization.metric.captionDirectionValue" = "Basit ve spesifik tutun";
"analysis.photoOptimization.metric.captionDirectionDetail" = "Altyazı yönü, görüntüyü en iyi destekleyen tonu önerir. Kısa, somut bir başlık genellikle fotoğrafı aşırı açıklamaktan daha iyi sonuç verir. Altyazıyı görünen ayar, ruh hali veya etkinlikle eşleştirin.";
"analysis.photoOptimization.metric.postingFix" = "Gönderim Düzeltmesi";
"analysis.photoOptimization.metric.postingFixValue" = "Göndermeden önce ekin temizleyici";
"analysis.photoOptimization.metric.postingFixDetail" = "Gönderi düzeltme, görsel yayınlanmadan önce yapılan en hızlı düzenlemedir. Kırpmayı iyileştirin, arka plandaki dikkat dağıtıcı unsurları azaltın ve yüzü telefon ekranı boyutunda yeterince parlak tutun. Cilt tonunu değiştiren veya gözleri daha az net hale getiren filtrelerden kaçının.";
"analysis.aestheticsResults.shapes" = "Şekiller";
"analysis.aestheticsResults.badge.unlocked" = "KİLİDİ AÇILDI";
"analysis.aestheticsResults.proportions" = "Oranlar";
"analysis.aestheticsResults.shape.faceShape" = "Yüz Şekli";
"analysis.aestheticsResults.shape.faceShapeValue" = "Oval";
"analysis.aestheticsResults.shape.faceShapeDetail" = "Oval yüz şekli, fotoğrafa hafifçe sivrilen alt üçte birlik kısımla dengeli bir taslak verir.";
"analysis.aestheticsResults.shape.eyeShape" = "Göz Şekli";
"analysis.aestheticsResults.shape.eyeShapeValue" = "Düştü";
"analysis.aestheticsResults.shape.eyeShapeDetail" = "Aşağıya dönük göz şekli daha yumuşak, daha rahat bir göz çizgisi olarak görünür. Şekillendirme dış köşeyi görsel olarak kaldırabilir.";
"analysis.aestheticsResults.shape.eyebrowShape" = "Kaş Şekli";
"analysis.aestheticsResults.shape.eyebrowShapeValue" = "Kemer (Dış kuyruk)";
"analysis.aestheticsResults.shape.eyebrowShapeDetail" = "Dış kuyruk kemeri, ifadeyi çok şiddetli göstermeden gözlerin üzerine yapı katar.";
"analysis.aestheticsResults.shape.lipShape" = "Dudak Şekli";
"analysis.aestheticsResults.shape.lipShapeValue" = "Yukarı Döndü";
"analysis.aestheticsResults.shape.lipShapeDetail" = "Yukarı dönük dudak şekli, nötr bir pozda bile yüzün alt kısmına biraz daha sıcak bir ifade verir.";
"analysis.aestheticsResults.proportion.canthalTilt" = "Canthal Eğimi";
"analysis.aestheticsResults.proportion.canthalTiltValue" = "6,8°";
"analysis.aestheticsResults.proportion.canthalTiltDetail" = "İçten dışa göz köşesi açısı. Pozitif bir eğim, göz bölgesinin daha keskin ve daha dikkatli okunmasını sağlayabilir.";
"analysis.aestheticsResults.proportion.eyeSpacingRatio" = "Göz Aralığı Oranı (ESR)";
"analysis.aestheticsResults.proportion.eyeSpacingRatioValue" = "0.46";
"analysis.aestheticsResults.proportion.eyeSpacingRatioDetail" = "Göz genişliğiyle karşılaştırıldığında göz aralığı. 0,46 bu yüz kırpması için normal dengeli bir aralıkta yer alıyor.";
"analysis.aestheticsResults.proportion.faceWidthHeightRatio" = "Yüz Genişlik-Yükseklik Oranı";
"analysis.aestheticsResults.proportion.faceWidthHeightRatioValue" = "1.71";
"analysis.aestheticsResults.proportion.faceWidthHeightRatioDetail" = "Yüz genişliği ÷ yüz yüksekliği. İdeal ≈ Erkekler için 1,8 ila 2,0 ve kadınlar için 1,6 ila 1,8. Tipik aralık dahilindeki daha yüksek bir fWHR, baskınlık algılarıyla ilişkilendirilebilir.";
"analysis.aestheticsResults.proportion.midfaceRatio" = "Orta Yüz Oranı";
"analysis.aestheticsResults.proportion.midfaceRatioValue" = "0.90";
"analysis.aestheticsResults.proportion.midfaceRatioDetail" = "Yüz genişliğiyle karşılaştırıldığında orta yüz yüksekliği. 0,90, bu görüşe göre kompakt orta üçte bir oranlara işaret ediyor.";
"analysis.aestheticsResults.proportion.philtrumToChinRatio" = "Philtrum/Çene Oranı";
"analysis.aestheticsResults.proportion.philtrumToChinRatioValue" = "1:2,0";
"analysis.aestheticsResults.proportion.philtrumToChinRatioDetail" = "Philtrum uzunluğu ÷ alt yüz üçte biri. 1:2 oranı gençliği ve orantıyı gösterir. Daha yüksek değerler daha erkeksi ve baskın olarak okunabilir.";
"analysis.aestheticsResults.proportion.eyeWidthFaceRatio" = "Göz Genişliği-Yüz Oranı";
"analysis.aestheticsResults.proportion.eyeWidthFaceRatioValue" = "0.23";
"analysis.aestheticsResults.proportion.eyeWidthFaceRatioDetail" = "Toplam yüz genişliğiyle karşılaştırıldığında göz genişliği. Bu değer aşırı dar görünmeden göz çevresinin orantılı kalmasını sağlar.";
"analysis.aestheticsResults.proportion.upperLipToLowerLip" = "Üst Dudaktan Alt Dudağa";
"analysis.aestheticsResults.proportion.upperLipToLowerLipValue" = "1:1.4";
"analysis.aestheticsResults.proportion.upperLipToLowerLipDetail" = "Üst dudak ile alt dudağın karşılaştırılması. Bu oran, biraz daha güçlü görsel ağırlığa sahip bir alt dudağı akla getiriyor.";
"analysis.aestheticsResults.proportion.eyeWidthHeightRatio" = "Göz Genişliği-Yükseklik Oranı";
"analysis.aestheticsResults.proportion.eyeWidthHeightRatioValue" = "2.9";
"analysis.aestheticsResults.proportion.eyeWidthHeightRatioDetail" = "Göz yüksekliğiyle karşılaştırıldığında göz genişliği. 2.9, daha temiz bir yatay çizgiye sahip uzun bir göz şekli olarak okunur.";
"analysis.aestheticsResults.proportion.lowerToFullFaceRatio" = "Daha Düşük/Tam Yüz Oranı";
"analysis.aestheticsResults.proportion.lowerToFullFaceRatioValue" = "0.69";
"analysis.aestheticsResults.proportion.lowerToFullFaceRatioDetail" = "Tam yüz yüksekliğine kıyasla daha düşük yüz yüksekliği. Bu değer, yüzü aşırı zorlamadan alt üçüncünün fark edilebilir varlığını sağlar.";
"analysis.aestheticsResults.proportion.eyeToMouthAngle" = "Gözden Ağza Açısı";
"analysis.aestheticsResults.proportion.eyeToMouthAngleValue" = "45,7°";
"analysis.aestheticsResults.proportion.eyeToMouthAngleDetail" = "Gözden ağza çapraz açı, yüz akışının tahmin edilmesine yardımcı olur. Bu değer gözlerden ağza doğru sabit bir aşağı doğru çerçeveyi akla getirir.";
"analysis.aestheticsResults.proportion.faceDepthWidthRatio" = "Yüz Derinliği-Genişlik Oranı";
"analysis.aestheticsResults.proportion.faceDepthWidthRatioDetail" = "Yüz ağı ve görüntü bağlamı kullanılarak tahmini yüz derinliğinin görünür genişlikle karşılaştırılması. Dengeli bir derinlik-genişlik okuması yüzün aşırı dar görünmeden daha boyutlu görünmesini sağlayabilir.";
"analysis.aestheticsResults.proportion.faceContourWidthHeightRatio" = "Yüz Kontur Genişlik-Yükseklik Oranı";
"analysis.aestheticsResults.proportion.faceContourWidthHeightRatioDetail" = "Yüksekliğe kıyasla dış yüz kontur genişliği. Bu, kompakt, dikey veya daha geniş bir yüz çerçevesini yalnızca kamera perspektifinden ayırmaya yardımcı olur.";
"analysis.glowUpCoach.facialAnalysis" = "Yüz Analizi";
"analysis.glowUpCoach.needsWork" = "Çalışmaya İhtiyaç Duyuyor";
"analysis.glowUpCoach.yourStrengths" = "Güçlü Yönleriniz";
"analysis.glowUpCoach.summary" = "Özet";
"analysis.glowUpCoach.summaryBody" = "Berrak bir cilde, simetrik özelliklere ve bakımlı bir görünüme sahip, ışıltılı bir görünüm için güçlü bir temele sahipsiniz. Odaklanılacak ana alan ifade, kamera açısı ve ince stil seçimleriyle daha fazla sıcaklık ve güven yansıtmaktır. Genel olarak, zaten harika gidiyorsunuz. Birkaç küçük sunum yükseltmesi görünümünüzü daha da iyi hale getirebilir.";
"analysis.glowUpCoach.item.symmetry" = "Simetri";
"analysis.glowUpCoach.item.symmetryAssessment" = "Değerlendirme: Yüzünüz oldukça simetrik görünüyor, her iki tarafta da dengeli özellikler var ve bu fotoğrafta büyük bir görsel dengesizlik yok.";
"analysis.glowUpCoach.item.symmetryAction" = "Plan: Fotoğrafları düz tutun ve güçlü yan ışıktan kaçının, böylece yüzünüzün doğal dengesi net kalır.";
"analysis.glowUpCoach.item.skin" = "Görünüm";
"analysis.glowUpCoach.item.skinAssessment" = "Değerlendirme: Cildiniz minimum düzeyde leke veya kızarıklıkla pürüzsüz, temiz ve eşit tonda görünüyor. Cildinizde sağlıklı, doğal bir görünüm var.";
"analysis.glowUpCoach.item.skinAction" = "Plan: Tutarlı bir cilt bakımı rutinine devam edin: her gün hafif temizleyici, nemlendirici ve güneş kremi. Ekstra parlaklık için nemlendirici bir serum veya haftalık peeling tedavisi eklemeyi düşünün.";
"analysis.glowUpCoach.item.jawline" = "Çene çizgisi";
"analysis.glowUpCoach.item.jawlineAssessment" = "Değerlendirme: Çene hattınız temiz ve orantılı, sert görünmeden alt yüzü destekleyecek kadar belirgin.";
"analysis.glowUpCoach.item.jawlineAction" = "Plan: Çene çizgisinin fotoğraflarda daha keskin görünmesini sağlamak için biraz daha yüksek bir kamera açısı ve rahat bir boyun duruşu kullanın.";
"analysis.glowUpCoach.item.eyeArea" = "Göz Çevresi";
"analysis.glowUpCoach.item.eyeAreaAssessment" = "Değerlendirme: Göz çevreniz sakin ve dengeli bir görünüme sahip. Mevcut ifade nötrdür, bu da gözlerin çekingen hissetmesini sağlar.";
"analysis.glowUpCoach.item.eyeAreaAction" = "Plan: Daha parlak bir ışıkla ve gözlerin daha açık hissetmesini sağlamak için kaşları hafifçe kaldırarak ifadeyi hafifçe kaldırın.";
"analysis.glowUpCoach.item.cheekbones" = "Elmacık kemikleri";
"analysis.glowUpCoach.item.cheekbonesAssessment" = "Değerlendirme: Elmacık kemiği yapısı görülebilir ve özellikle önden ışık vurduğunda orta yüzü destekler.";
"analysis.glowUpCoach.item.cheekbonesAction" = "Plan: Yumuşak yönlendirmeli aydınlatma kullanın ve daha fazla yüz boyutu göstermek için düz tavan ışıklarından kaçının.";
"analysis.glowUpCoach.item.eyebrows" = "Kaşlar";
"analysis.glowUpCoach.item.eyebrowsAssessment" = "Değerlendirme: Kaşlarınız göz çevresini iyi çerçeveliyor ve yapı katıyor, ancak yakın fotoğraflarda kenarlar daha net okunabilir.";
"analysis.glowUpCoach.item.eyebrowsAction" = "Plan: Dağınık kılların etrafına hafif bakım yapmak, doğal kaş şeklinizi değiştirmeden göz çevresini keskinleştirebilir.";
"analysis.glowUpCoach.item.glow" = "Parıltı";
"analysis.glowUpCoach.item.glowAssessment" = "Değerlendirme: Genel parlaklık sağlam, berrak bir cilt ve dengeli bir yapıya sahip. Ana sınırlayıcı yüz özelliklerinden ziyade fotoğraf enerjisidir.";
"analysis.glowUpCoach.item.glowAction" = "Plan: Ön aydınlatmayı, duruşu ve ifadeyi iyileştirin. Bu değişiklikler fotoğraflarda en hızlı görünür parlamayı yaratır.";
"analysis.glowUpCoach.item.hair" = "Saç";
"analysis.glowUpCoach.item.hairAssessment" = "Değerlendirme: Saçınız yüz şeklinize uyuyor ve üst üçte birlik kısma hacim kazandırıyor.";
"analysis.glowUpCoach.item.hairAction" = "Plan: Üst kısmı dokulu ve kontrollü tutun. Daha temiz bir saçak veya yan akış alın ve göz bölgesini açabilir.";
"analysis.glowUpCoach.item.confidence" = "Güven";
"analysis.glowUpCoach.item.confidenceAssessment" = "Değerlendirme: Nötr ifade, fotoğrafın sakin ama biraz çekingen görünmesini sağlıyor.";
"analysis.glowUpCoach.item.confidenceAction" = "Plan: Rahat bir yarım gülümseme egzersizi yapın ve daha mevcut ve kendinden emin görünmenizi sağlayacak açıları test edin.";
"analysis.glowUpCoach.item.expressionConfidence" = "İfade/Güven";
"analysis.glowUpCoach.item.expressionConfidenceAssessment" = "Değerlendirme: Tarafsız bir ifade sakin görünebilir, ancak aynı zamanda fotoğrafın çekingen veya daha az ulaşılabilir görünmesine de neden olabilir.";
"analysis.glowUpCoach.item.expressionConfidenceAction" = "Plan: Rahat bir yarım gülümseme alıştırması yapın, gözlerinizi hafifçe kaldırın ve birkaç açıyı karşılaştırın, böylece ifade zoraki görünmeden daha sıcak hissedilir.";
"analysis.glowUpCoach.item.faceWidthHeightRatio" = "Yüz Uzunluğu/Genişlik Oranı";
"analysis.glowUpCoach.item.faceWidthHeightRatioAssessment" = "Değerlendirme: Görünür yüz uzunluğu ve genişliği ilişkisi, öne bakan bir fotoğrafta yüzün kompakt, uzun veya dengeli okunmasını etkiler.";
"analysis.glowUpCoach.item.faceWidthHeightRatioAction" = "Plan: Düz bir lens açısı kullanın, kamerayı göz hizasında tutun ve doğal yüz çerçevesinin doğru okunması için aşırı yakın çekim bozulmalarından kaçının.";
"analysis.glowUpCoach.item.cameraAngle" = "Kamera Açısı";
"analysis.glowUpCoach.item.cameraAngleAssessment" = "Değerlendirme: Kamera yüksekliği ve eğimi, temel özellikler dengeli olduğunda bile çene çizgisi, orta yüz ve alın oranlarının görünümünü değiştirebilir.";
"analysis.glowUpCoach.item.cameraAngleAction" = "Plan: Göz hizasından veya biraz yukarıdan çekim yapın, başınızı ortalayın ve telefonu çenenin altından yukarıya doğru eğmekten kaçının.";
"analysis.glowUpCoach.item.lighting" = "Aydınlatma";
"analysis.glowUpCoach.item.lightingAssessment" = "Değerlendirme: Düzensiz veya yukarıdan gelen ışık cilt dokusunu düzleştirebilir, gölgeleri abartabilir ve simetrinin okunmasını zorlaştırabilir.";
"analysis.glowUpCoach.item.lightingAction" = "Planlayın: Büyük bir pencereye veya yumuşak bir ön ışığa bakın, ardından gözlerin veya yüzün alt kısmında sert üst gölgeler olmadan fotoğrafı yeniden çekin.";
"analysis.glowUpCoach.item.grooming" = "Bakım";
"analysis.glowUpCoach.item.groomingAssessment" = "Değerlendirme: Kaşların, saç kenarlarının ve yüz kıllarının etrafındaki küçük bakım ayrıntıları tüm yüzün ne kadar parlak göründüğünü değiştirebilir.";
"analysis.glowUpCoach.item.groomingAction" = "Plan: Önce yalnızca başıboş kenarları temizleyin, doğal şekli koruyun ve daha büyük değişiklikler yapmadan önce sonuçları aynı ışıkta karşılaştırın.";
"analysis.glowUpCoach.item.photoPresence" = "Fotoğraf Varlığı";
"analysis.glowUpCoach.item.photoPresenceAssessment" = "Değerlendirme: Duruş, göz teması ve ifade, güçlü özelliklerin kendine güvenen bir fotoğrafa dönüşüp dönüşmeyeceğini belirler.";
"analysis.glowUpCoach.item.photoPresenceAction" = "Plan: Boynunuzu uzatın, omuzlarınızı gevşetin, doğrudan mercekten bakın ve küçük bir ifade değişikliğiyle birkaç kare çekin.";
"analysis.glowUpCoach.item.skinQuality" = "Cilt Kalitesi";
"analysis.glowUpCoach.item.skinQualityAssessment" = "Değerlendirme: Cilt kaliteniz, temiz bir ton ve minimum görünür doku sorunlarıyla bu taramanın en güçlü kısımlarından biridir.";
"analysis.glowUpCoach.item.skinQualityAction" = "Plan: Bu avantajı günlük güneş kremi, sıvı alımı ve tutarlı uyku ile korumaya devam edin.";
"analysis.glowUpCoach.item.harmony" = "Uyum";
"analysis.glowUpCoach.item.harmonyAssessment" = "Değerlendirme: Yüz dengeniz genel olarak stabil görünüyor, bu da taramanın tek bir özelliğe doğru çekilmek yerine tutarlı hissettirmesini sağlıyor.";
"analysis.glowUpCoach.item.harmonyAction" = "Plan: Kamerayı düz tutun ve basit bir stil kullanın, böylece bu doğal denge ana sinyal olarak kalır.";
"analysis.glowUpCoach.item.eyeAreaStrengthAssessment" = "Değerlendirme: Göz bölgesi sakin, temiz bir izlenim verir ve yüzün yaklaşılabilir hissetmesine yardımcı olur.";
"analysis.glowUpCoach.item.eyeAreaStrengthAction" = "Plan: Bu özelliği net tutmak için daha yumuşak ışık kullanın ve gözlerin üzerinde yoğun gölgelerden kaçının.";
