"analysis.photoOptimization.metric.bestPickReadiness" = "Best Pick Readiness";
"analysis.photoOptimization.metric.bestPickReadinessValue" = "7.4 · Usable main pick";
"analysis.photoOptimization.metric.bestPickReadinessDetail" = "This checks whether the photo is strong enough to be used as the lead image. A good result means the face is readable, the photo feels intentional, and there are no obvious distractions. If the score is close but not elite, one cleaner retake can usually beat it.";
"analysis.photoOptimization.metric.faceVisibility" = "Face Visibility";
"analysis.photoOptimization.metric.faceVisibilityValue" = "7.6 · Clear read";
"analysis.photoOptimization.metric.faceVisibilityDetail" = "Face visibility measures how easily the viewer can read the eyes, expression, and facial outline. Strong visibility makes the photo feel more trustworthy and polished. Keep the face unobstructed and avoid crops that hide the eye area.";
"analysis.photoOptimization.metric.expressionWarmth" = "Expression Warmth";
"analysis.photoOptimization.metric.expressionWarmthValue" = "6.9 · Slightly reserved";
"analysis.photoOptimization.metric.expressionWarmthDetail" = "Expression warmth looks at whether the photo feels relaxed, open, and easy to approach. A neutral expression can work, but a small half-smile usually improves the first read. The goal is natural presence, not a forced grin.";
"analysis.photoOptimization.metric.lightingQuality" = "Lighting Quality";
"analysis.photoOptimization.metric.lightingQualityValue" = "7.1 · Solid, improvable";
"analysis.photoOptimization.metric.lightingQualityDetail" = "Lighting quality measures how evenly the face is lit and whether shadows help or hurt the structure. Soft front light usually makes skin, eyes, and symmetry read cleaner. Avoid harsh overhead light or dark side shadows for profile-use photos.";
"analysis.photoOptimization.metric.composition" = "Composition";
"analysis.photoOptimization.metric.compositionValue" = "7.2 · Well framed";
"analysis.photoOptimization.metric.compositionDetail" = "Composition checks the crop, head position, and visual balance around the face. A strong composition keeps attention on the face without feeling cramped. Leave enough space around the head and keep the eyes near the upper third.";
"analysis.photoOptimization.metric.backgroundControl" = "Background Control";
"analysis.photoOptimization.metric.backgroundControlValue" = "6.8 · Needs cleanup";
"analysis.photoOptimization.metric.backgroundControlDetail" = "Background control measures whether the setting supports the photo or competes with the face. Simple, clean backgrounds make the whole image feel more premium. Remove clutter, bright objects, and awkward lines near the head.";
"analysis.photoOptimization.metric.winningMove" = "Winning Move";
"analysis.photoOptimization.metric.winningMoveValue" = "Retake with softer front light";
"analysis.photoOptimization.metric.winningMoveDetail" = "The winning move is the single highest-impact change for the next version of the photo. In most cases, better light and a cleaner crop improve the result more than heavy editing. Make one clear change, then compare against this image.";
"analysis.photoOptimization.metric.retakeLight" = "Retake Light";
"analysis.photoOptimization.metric.retakeLightValue" = "Window light from front-left";
"analysis.photoOptimization.metric.retakeLightDetail" = "Retake light defines the most useful lighting setup for the next version. Soft front-side window light adds catchlights and keeps skin texture cleaner without flattening the face. Keep the phone steady and avoid strong overhead light.";
"analysis.photoOptimization.metric.editCleanup" = "Edit Cleanup";
"analysis.photoOptimization.metric.editCleanupValue" = "Reduce background distractions";
"analysis.photoOptimization.metric.editCleanupDetail" = "Edit cleanup focuses on small corrections that make the image feel intentional. A mild background blur, tighter crop, or exposure adjustment can improve focus without making the photo look overedited. Keep facial texture natural.";
"analysis.photoOptimization.metric.bestAngle" = "Best Angle";
"analysis.photoOptimization.metric.bestAngleValue" = "Slightly above eye level";
"analysis.photoOptimization.metric.bestAngleDetail" = "Best angle identifies the camera position most likely to flatter the current face structure. A small height adjustment can sharpen the jaw, reduce distortion, and keep the eyes readable. Retake several frames from the same distance before changing expression.";
"analysis.photoOptimization.metric.frontRead" = "Front Read";
"analysis.photoOptimization.metric.frontReadValue" = "7.3 · Stable";
"analysis.photoOptimization.metric.frontReadDetail" = "Front read checks how balanced the face appears in a direct camera-facing shot. A stable front read is useful for clear profile photos and ID-style crops. Keep the phone straight and avoid lens tilt that stretches the lower face.";
"analysis.photoOptimization.metric.leftRead" = "Left-Side Read";
"analysis.photoOptimization.metric.leftReadValue" = "7.1 · Worth testing";
"analysis.photoOptimization.metric.leftReadDetail" = "Left-side read estimates how the face may present from a slight left turn. This angle can add structure when the front view feels flat. Test a small turn first rather than a dramatic side profile.";
"analysis.photoOptimization.metric.rightRead" = "Right-Side Read";
"analysis.photoOptimization.metric.rightReadValue" = "7.0 · Worth testing";
"analysis.photoOptimization.metric.rightReadDetail" = "Right-side read estimates how the face may present from a slight right turn. It is useful for finding the side that gives better jaw and cheek definition. Compare it under the same light so the angle is the only variable.";
"analysis.photoOptimization.metric.cameraHeight" = "Camera Height";
"analysis.photoOptimization.metric.cameraHeightValue" = "Eye level to slightly high";
"analysis.photoOptimization.metric.cameraHeightDetail" = "Camera height affects the jawline, forehead, and midface more than most people expect. Eye level or slightly above usually keeps proportions natural while improving the facial outline. Avoid shooting from below the chin for main profile photos.";
"analysis.photoOptimization.metric.avoidAngle" = "Angle to Avoid";
"analysis.photoOptimization.metric.avoidAngleValue" = "Low, close selfie angle";
"analysis.photoOptimization.metric.avoidAngleDetail" = "This flags the perspective most likely to weaken the photo. Low close-up angles can exaggerate the lower face, flatten the eyes, and make the crop feel casual. Step back, use mild zoom if available, and keep the lens straighter.";
"analysis.photoOptimization.metric.retakePlan" = "Retake Plan";
"analysis.photoOptimization.metric.retakePlanValue" = "Same pose, cleaner setup";
"analysis.photoOptimization.metric.retakePlanDetail" = "A retake plan turns the analysis into a repeatable next shot. Use soft front light, hold the camera just above eye level, and take multiple frames with small head turns. Pick the version where the eyes, jawline, and expression all read cleanly.";
"analysis.photoOptimization.metric.mainPhotoSuitability" = "Main Photo Suitability";
"analysis.photoOptimization.metric.mainPhotoSuitabilityValue" = "7.2 · Good backup";
"analysis.photoOptimization.metric.mainPhotoSuitabilityDetail" = "This measures whether the image can work as the first dating-app photo. The lead photo needs clarity, warmth, and enough personality to stop a quick swipe. If the face is clear but the energy is quiet, use it as a backup or retake with more presence.";
"analysis.photoOptimization.metric.approachability" = "Approachability";
"analysis.photoOptimization.metric.approachabilityValue" = "7.0 · Friendly enough";
"analysis.photoOptimization.metric.approachabilityDetail" = "Approachability measures whether the photo feels easy to engage with. Softer eyes, relaxed posture, and a mild smile can change the read quickly. Avoid expressions that feel blank, tense, or overly posed.";
"analysis.photoOptimization.metric.confidenceSignal" = "Confidence Signal";
"analysis.photoOptimization.metric.confidenceSignalValue" = "7.1 · Calm confidence";
"analysis.photoOptimization.metric.confidenceSignalDetail" = "Confidence signal comes from posture, eye contact, framing, and expression. The strongest version feels composed without looking stiff. Keep the shoulders relaxed and look through the lens rather than at the screen.";
"analysis.photoOptimization.metric.trustSignal" = "Trust Signal";
"analysis.photoOptimization.metric.trustSignalValue" = "7.3 · Clear and credible";
"analysis.photoOptimization.metric.trustSignalDetail" = "Trust signal checks whether the image feels authentic, current, and easy to understand. Clear lighting and an unfiltered face usually raise this score. Avoid heavy edits, hidden eyes, and settings that make the photo feel ambiguous.";
"analysis.photoOptimization.metric.conversationHook" = "Conversation Hook";
"analysis.photoOptimization.metric.conversationHookValue" = "6.6 · Needs a stronger cue";
"analysis.photoOptimization.metric.conversationHookDetail" = "Conversation hook measures whether the photo gives someone an easy reason to comment. A setting, activity, or styling detail can make the profile feel more memorable. Keep the hook subtle so it supports the face instead of distracting from it.";
"analysis.photoOptimization.metric.photoMix" = "Photo Mix";
"analysis.photoOptimization.metric.photoMixValue" = "Add context and variety";
"analysis.photoOptimization.metric.photoMixDetail" = "Photo mix looks at what this image should do inside a broader profile set. A strong set usually includes one clear face photo, one full-body or style shot, and one social or activity image. This photo should fill the role it handles best instead of trying to do everything.";
"analysis.photoOptimization.metric.avoidProfile" = "Profile Mistake to Avoid";
"analysis.photoOptimization.metric.avoidProfileValue" = "Do not lead with low energy";
"analysis.photoOptimization.metric.avoidProfileDetail" = "This flags the profile choice most likely to lower results. Avoid leading with a dim, flat, overly cropped, or emotionally closed image. The first photo should make the face and vibe obvious within one second.";
"analysis.photoOptimization.metric.profileCrop" = "Profile Crop";
"analysis.photoOptimization.metric.profileCropValue" = "7.2 · Thumbnail readable";
"analysis.photoOptimization.metric.profileCropDetail" = "Profile crop measures whether the image still works when reduced to a small circle or square. The eyes and face outline need to stay readable at thumbnail size. Avoid placing the face too low, too small, or too close to an edge.";
"analysis.photoOptimization.metric.firstImpression" = "First Impression";
"analysis.photoOptimization.metric.firstImpressionValue" = "7.3 · Clean first read";
"analysis.photoOptimization.metric.firstImpressionDetail" = "First impression measures the immediate visual read before someone studies the details. Strong first impressions are clear, intentional, and emotionally easy to place. Improve this by simplifying the frame and making the expression more decisive.";
"analysis.photoOptimization.metric.feedFit" = "Feed Fit";
"analysis.photoOptimization.metric.feedFitValue" = "7.0 · Fits with polish";
"analysis.photoOptimization.metric.feedFitDetail" = "Feed fit checks whether the image would sit naturally in an Instagram grid or social profile. Color, crop, contrast, and styling all affect whether it feels cohesive. Use a consistent lighting style if you want the profile to look curated.";
"analysis.photoOptimization.metric.storyThumbnail" = "Story Thumbnail";
"analysis.photoOptimization.metric.storyThumbnailValue" = "6.9 · Needs bolder framing";
"analysis.photoOptimization.metric.storyThumbnailDetail" = "Story thumbnail measures whether the image remains readable in small, fast-viewed placements. A clear face, simple background, and stronger contrast help. If the photo feels too subtle, crop tighter around the face and upper body.";
"analysis.photoOptimization.metric.visualConsistency" = "Visual Consistency";
"analysis.photoOptimization.metric.visualConsistencyValue" = "7.1 · Mostly cohesive";
"analysis.photoOptimization.metric.visualConsistencyDetail" = "Visual consistency measures how well the photo's color, light, and styling match a polished profile direction. Consistency makes the profile feel intentional instead of random. Pick one lighting mood and repeat it across your best photos.";
"analysis.photoOptimization.metric.captionDirection" = "Caption Direction";
"analysis.photoOptimization.metric.captionDirectionValue" = "Keep it simple and specific";
"analysis.photoOptimization.metric.captionDirectionDetail" = "Caption direction suggests the tone that best supports the image. A short, concrete caption usually works better than overexplaining the photo. Match the caption to the visible setting, mood, or activity.";
"analysis.photoOptimization.metric.postingFix" = "Posting Fix";
"analysis.photoOptimization.metric.postingFixValue" = "Crop cleaner before posting";
"analysis.photoOptimization.metric.postingFixDetail" = "Posting fix is the quickest edit before the image goes live. Improve the crop, reduce background distractions, and keep the face bright enough at phone-screen size. Avoid filters that change skin tone or make the eyes less clear.";
"analysis.aestheticsResults.shapes" = "Shapes";
"analysis.aestheticsResults.badge.unlocked" = "UNLOCKED";
"analysis.aestheticsResults.proportions" = "Proportions";
"analysis.aestheticsResults.shape.faceShape" = "Face Shape";
"analysis.aestheticsResults.shape.faceShapeValue" = "Oval";
"analysis.aestheticsResults.shape.faceShapeDetail" = "Oval face shape gives the photo a balanced outline with a softly tapered lower third.";
"analysis.aestheticsResults.shape.eyeShape" = "Eye Shape";
"analysis.aestheticsResults.shape.eyeShapeValue" = "Downturned";
"analysis.aestheticsResults.shape.eyeShapeDetail" = "Downturned eye shape reads as a softer, more relaxed eye line. Styling can lift the outer corner visually.";
"analysis.aestheticsResults.shape.eyebrowShape" = "Eyebrow Shape";
"analysis.aestheticsResults.shape.eyebrowShapeValue" = "Arch (Outer tail)";
"analysis.aestheticsResults.shape.eyebrowShapeDetail" = "Outer-tail arch adds structure above the eyes without making the expression look too severe.";
"analysis.aestheticsResults.shape.lipShape" = "Lip Shape";
"analysis.aestheticsResults.shape.lipShapeValue" = "Upturned";
"analysis.aestheticsResults.shape.lipShapeDetail" = "Upturned lip shape gives the lower face a slightly warmer expression even in a neutral pose.";
"analysis.aestheticsResults.proportion.canthalTilt" = "Canthal Tilt";
"analysis.aestheticsResults.proportion.canthalTiltValue" = "6.8°";
"analysis.aestheticsResults.proportion.canthalTiltDetail" = "Inner-to-outer eye corner angle. A positive tilt can make the eye area read sharper and more alert.";
"analysis.aestheticsResults.proportion.eyeSpacingRatio" = "Eye Spacing Ratio (ESR)";
"analysis.aestheticsResults.proportion.eyeSpacingRatioValue" = "0.46";
"analysis.aestheticsResults.proportion.eyeSpacingRatioDetail" = "Eye gap compared with eye width. 0.46 sits in a normal balanced range for this face crop.";
"analysis.aestheticsResults.proportion.faceWidthHeightRatio" = "Face Width-Height Ratio";
"analysis.aestheticsResults.proportion.faceWidthHeightRatioValue" = "1.71";
"analysis.aestheticsResults.proportion.faceWidthHeightRatioDetail" = "Face width ÷ face height. Ideal ≈ 1.8 to 2.0 for men and 1.6 to 1.8 for women. A higher fWHR, within the typical range, can be associated with perceptions of dominance.";
"analysis.aestheticsResults.proportion.midfaceRatio" = "Midface Ratio";
"analysis.aestheticsResults.proportion.midfaceRatioValue" = "0.90";
"analysis.aestheticsResults.proportion.midfaceRatioDetail" = "Midface height compared with facial width. 0.90 suggests compact middle-third proportions in this view.";
"analysis.aestheticsResults.proportion.philtrumToChinRatio" = "Philtrum to Chin Ratio";
"analysis.aestheticsResults.proportion.philtrumToChinRatioValue" = "1:2.0";
"analysis.aestheticsResults.proportion.philtrumToChinRatioDetail" = "Philtrum length ÷ lower face third. 1:2 ratio indicates youthfulness and proportion. Higher values can read more masculine and dominant.";
"analysis.aestheticsResults.proportion.eyeWidthFaceRatio" = "Eye Width-Face Ratio";
"analysis.aestheticsResults.proportion.eyeWidthFaceRatioValue" = "0.23";
"analysis.aestheticsResults.proportion.eyeWidthFaceRatioDetail" = "Eye width compared with total face width. This value keeps the eye area proportional without looking overly narrow.";
"analysis.aestheticsResults.proportion.upperLipToLowerLip" = "Upper Lip to Lower Lip";
"analysis.aestheticsResults.proportion.upperLipToLowerLipValue" = "1:1.4";
"analysis.aestheticsResults.proportion.upperLipToLowerLipDetail" = "Upper lip compared with lower lip. This ratio suggests a lower lip with slightly stronger visual weight.";
"analysis.aestheticsResults.proportion.eyeWidthHeightRatio" = "Eye Width-Height Ratio";
"analysis.aestheticsResults.proportion.eyeWidthHeightRatioValue" = "2.9";
"analysis.aestheticsResults.proportion.eyeWidthHeightRatioDetail" = "Eye width compared with eye height. 2.9 reads as an elongated eye shape with a cleaner horizontal line.";
"analysis.aestheticsResults.proportion.lowerToFullFaceRatio" = "Lower to Full Face Ratio";
"analysis.aestheticsResults.proportion.lowerToFullFaceRatioValue" = "0.69";
"analysis.aestheticsResults.proportion.lowerToFullFaceRatioDetail" = "Lower face height compared with full face height. This value gives the lower third noticeable presence without overpowering the face.";
"analysis.aestheticsResults.proportion.eyeToMouthAngle" = "Eye to Mouth Angle";
"analysis.aestheticsResults.proportion.eyeToMouthAngleValue" = "45.7°";
"analysis.aestheticsResults.proportion.eyeToMouthAngleDetail" = "Eye-to-mouth diagonal angle helps estimate facial flow. This value suggests a stable downward frame from eyes to mouth.";
"analysis.aestheticsResults.proportion.faceDepthWidthRatio" = "Face Depth-Width Ratio";
"analysis.aestheticsResults.proportion.faceDepthWidthRatioDetail" = "Estimated facial depth compared with visible width, using the face mesh and image context. A balanced depth-to-width read can make the face look more dimensional without appearing overly narrow.";
"analysis.aestheticsResults.proportion.faceContourWidthHeightRatio" = "Face Contour Width-Height Ratio";
"analysis.aestheticsResults.proportion.faceContourWidthHeightRatioDetail" = "Outer facial contour width compared with height. This helps separate a compact, vertical, or wider facial frame from camera perspective alone.";
"analysis.glowUpCoach.facialAnalysis" = "Facial Analysis";
"analysis.glowUpCoach.needsWork" = "Needs Work";
"analysis.glowUpCoach.yourStrengths" = "Your Strengths";
"analysis.glowUpCoach.summary" = "Summary";
"analysis.glowUpCoach.summaryBody" = "You have a strong foundation for a glow-up, with clear skin, symmetrical features, and a well-groomed appearance. The main area to focus on is projecting more warmth and confidence through expression, camera angle, and subtle styling choices. Overall, you are already doing great. A few small presentation upgrades can elevate your look even further.";
"analysis.glowUpCoach.item.symmetry" = "Symmetry";
"analysis.glowUpCoach.item.symmetryAssessment" = "Assessment: Your face appears quite symmetrical, with balanced features on both sides and no major visual imbalance in this photo.";
"analysis.glowUpCoach.item.symmetryAction" = "Plan: Keep photos straight-on and avoid strong side lighting so the natural balance of your face stays clear.";
"analysis.glowUpCoach.item.skin" = "Skin";
"analysis.glowUpCoach.item.skinAssessment" = "Assessment: Your skin looks smooth, clear, and even-toned with minimal blemishes or redness. There is a healthy, natural look to your complexion.";
"analysis.glowUpCoach.item.skinAction" = "Plan: Continue with a consistent skincare routine: gentle cleanser, moisturizer, and sunscreen daily. For extra glow, consider adding a hydrating serum or a weekly exfoliating treatment.";
"analysis.glowUpCoach.item.jawline" = "Jawline";
"analysis.glowUpCoach.item.jawlineAssessment" = "Assessment: Your jawline reads clean and proportionate, with enough definition to support the lower face without looking harsh.";
"analysis.glowUpCoach.item.jawlineAction" = "Plan: Use a slightly higher camera angle and relaxed neck posture to make the jawline look sharper in photos.";
"analysis.glowUpCoach.item.eyeArea" = "Eye Area";
"analysis.glowUpCoach.item.eyeAreaAssessment" = "Assessment: Your eye area has a calm, balanced look. The current expression is neutral, which makes the eyes feel reserved.";
"analysis.glowUpCoach.item.eyeAreaAction" = "Plan: Lift the expression gently with brighter lighting and a subtle brow raise to make the eyes feel more open.";
"analysis.glowUpCoach.item.cheekbones" = "Cheekbones";
"analysis.glowUpCoach.item.cheekbonesAssessment" = "Assessment: Cheekbone structure is visible and supports the midface, especially when light hits from the front.";
"analysis.glowUpCoach.item.cheekbonesAction" = "Plan: Use soft directional lighting and avoid flat overhead light to show more facial dimension.";
"analysis.glowUpCoach.item.eyebrows" = "Eyebrows";
"analysis.glowUpCoach.item.eyebrowsAssessment" = "Assessment: Your brows frame the eye area well and add structure, but the edges could read cleaner in close photos.";
"analysis.glowUpCoach.item.eyebrowsAction" = "Plan: Light grooming around stray hairs can sharpen the eye area without changing your natural brow shape.";
"analysis.glowUpCoach.item.glow" = "Glow";
"analysis.glowUpCoach.item.glowAssessment" = "Assessment: The overall glow is solid, with clear skin and balanced structure. The main limiter is photo energy rather than facial features.";
"analysis.glowUpCoach.item.glowAction" = "Plan: Improve front lighting, posture, and expression. These changes create the fastest visible glow-up in photos.";
"analysis.glowUpCoach.item.hair" = "Hair";
"analysis.glowUpCoach.item.hairAssessment" = "Assessment: Your hair suits the face shape and adds volume around the upper third.";
"analysis.glowUpCoach.item.hairAction" = "Plan: Keep the top textured and controlled. A cleaner fringe or side flow can open the forehead and eye area.";
"analysis.glowUpCoach.item.confidence" = "Confidence";
"analysis.glowUpCoach.item.confidenceAssessment" = "Assessment: The neutral expression makes the photo feel calm but slightly reserved.";
"analysis.glowUpCoach.item.confidenceAction" = "Plan: Practice a relaxed half-smile and test angles that make you look more present and confident.";
"analysis.glowUpCoach.item.expressionConfidence" = "Expression/Confidence";
"analysis.glowUpCoach.item.expressionConfidenceAssessment" = "Assessment: A neutral expression can read calm, but it may also make the photo feel reserved or less approachable.";
"analysis.glowUpCoach.item.expressionConfidenceAction" = "Plan: Practice a relaxed half-smile, slightly lift the eyes, and compare a few angles so the expression feels warmer without looking forced.";
"analysis.glowUpCoach.item.faceWidthHeightRatio" = "Face Length/Width Ratio";
"analysis.glowUpCoach.item.faceWidthHeightRatioAssessment" = "Assessment: The visible face length and width relationship affects whether the face reads compact, elongated, or balanced in a front-facing photo.";
"analysis.glowUpCoach.item.faceWidthHeightRatioAction" = "Plan: Use a straight lens angle, keep the camera near eye level, and avoid extreme close-up distortion so the natural facial frame reads accurately.";
"analysis.glowUpCoach.item.cameraAngle" = "Camera Angle";
"analysis.glowUpCoach.item.cameraAngleAssessment" = "Assessment: Camera height and tilt can change how the jawline, midface, and forehead proportions appear even when the underlying features are balanced.";
"analysis.glowUpCoach.item.cameraAngleAction" = "Plan: Shoot from eye level or slightly above, keep the head centered, and avoid tilting the phone upward from below the chin.";
"analysis.glowUpCoach.item.lighting" = "Lighting";
"analysis.glowUpCoach.item.lightingAssessment" = "Assessment: Uneven or overhead light can flatten skin texture, exaggerate shadows, and make symmetry harder to read.";
"analysis.glowUpCoach.item.lightingAction" = "Plan: Face a large window or soft front light, then retake the photo without harsh top shadows across the eyes or lower face.";
"analysis.glowUpCoach.item.grooming" = "Grooming";
"analysis.glowUpCoach.item.groomingAssessment" = "Assessment: Small grooming details around brows, hair edges, and facial hair can change how polished the whole face reads.";
"analysis.glowUpCoach.item.groomingAction" = "Plan: Clean up only stray edges first, keep the natural shape, and compare the result in the same lighting before making bigger changes.";
"analysis.glowUpCoach.item.photoPresence" = "Photo Presence";
"analysis.glowUpCoach.item.photoPresenceAssessment" = "Assessment: Posture, eye contact, and expression determine whether strong features translate into a confident photo.";
"analysis.glowUpCoach.item.photoPresenceAction" = "Plan: Lengthen the neck, relax the shoulders, look directly through the lens, and take several frames with a small expression change.";
"analysis.glowUpCoach.item.skinQuality" = "Skin Quality";
"analysis.glowUpCoach.item.skinQualityAssessment" = "Assessment: Your skin quality is one of the strongest parts of this scan, with a clean tone and minimal visible texture issues.";
"analysis.glowUpCoach.item.skinQualityAction" = "Plan: Keep protecting that advantage with daily sunscreen, hydration, and consistent sleep.";
"analysis.glowUpCoach.item.harmony" = "Harmony";
"analysis.glowUpCoach.item.harmonyAssessment" = "Assessment: Your facial balance reads stable overall, which makes the scan feel coherent rather than pulled toward one feature.";
"analysis.glowUpCoach.item.harmonyAction" = "Plan: Keep the camera straight and use simple styling so this natural balance stays the main signal.";
"analysis.glowUpCoach.item.eyeAreaStrengthAssessment" = "Assessment: The eye area gives a calm, clean impression and helps the face feel approachable.";
"analysis.glowUpCoach.item.eyeAreaStrengthAction" = "Plan: Use softer light and avoid heavy shadows over the eyes to keep this feature clear.";
