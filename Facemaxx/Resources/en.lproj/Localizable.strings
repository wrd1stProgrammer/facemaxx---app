"analysis.photoOptimization.metric.styleSignalDetail" = "Style signal reads whether the photo gives a memorable personal cue. A clean photo is useful, but one stronger outfit, hair, background, or color choice makes the profile easier to remember. Add one intentional detail instead of adding more filters.";
"analysis.photoOptimization.metric.photoContextValue" = "Low story signal";
"analysis.photoOptimization.metric.photoContextDetail" = "Photo context checks whether the image tells people anything beyond the face. A place, activity, outfit, or social setting gives the profile a stronger story. If every shot is a close-up, add one image that shows where your energy lives.";
"analysis.photoOptimization.metric.redFlagRiskValue" = "Watch the cold read";
"analysis.photoOptimization.metric.redFlagRiskDetail" = "This flags anything that could make the profile feel less approachable than intended. Serious expression, dim light, hidden eyes, or too many similar selfies can create a colder read. Balance one composed photo with warmer light and at least one context shot.";
"analysis.photoOptimization.metric.profileRoleValue" = "Lead, backup, or support";
"analysis.photoOptimization.metric.profileRoleDetail" = "Every photo needs a job inside the set. One image should explain your face quickly, another can show style, and another should add lifestyle or social proof. Do not let several photos repeat the same role.";
"analysis.photoOptimization.metric.messageBaitValue" = "Add an easy opener";
"analysis.photoOptimization.metric.messageBaitDetail" = "Message bait is the small visual detail that makes the first message easier. A cafe, trip, outfit detail, hobby, food, book, gym, or location can give someone a natural first line. Keep it real so it feels like your life, not a prop.";
"analysis.photoOptimization.metric.missingShotValue" = "Lifestyle slot missing";
"analysis.photoOptimization.metric.missingShotDetail" = "The missing shot is usually not another face photo. Add a frame that shows activity, place, full outfit, or social context so the profile feels complete. This gives people more reasons to start a conversation.";
"analysis.photoOptimization.metric.openerAngleValue" = "Give them a first line";
"analysis.photoOptimization.metric.openerAngleDetail" = "Opener angle is the easiest thing someone could comment on after seeing the photo. The best angle is specific enough to react to but not forced. Add one visible cue that invites a simple question or playful comment.";
"analysis.photoOptimization.metric.thumbnailImpactValue" = "Readable when small";
"analysis.photoOptimization.metric.thumbnailImpactDetail" = "Thumbnail impact checks whether the photo still works when it becomes a tiny square or circle. Clear eyes, a simple crop, and contrast around the face make the image read faster. Preview the photo small before posting.";
"analysis.photoOptimization.metric.profileIconEnergyValue" = "Strong profile-icon base";
"analysis.photoOptimization.metric.profileIconEnergyDetail" = "Profile icon energy measures whether this can carry the whole account at a glance. The face should feel clear, current, and recognizable without needing the full-size image. Tighten the crop and keep the background quiet.";
"analysis.photoOptimization.metric.scrollStopPowerValue" = "Subtle, not loud";
"analysis.photoOptimization.metric.scrollStopPowerDetail" = "Scroll-stop power asks whether the image can interrupt a fast feed. A clean photo can still feel too quiet if the eyes, contrast, or pose do not hit quickly. Add brighter eye-level light or stronger framing for more impact.";
"analysis.photoOptimization.metric.colorMoodValue" = "Neutral profile mood";
"analysis.photoOptimization.metric.colorMoodDetail" = "Color mood checks whether the edit fits the profile direction. Natural skin tone, consistent exposure, and a controlled background make the profile feel planned. Avoid filters that flatten the face or fight the surrounding grid.";
"analysis.photoOptimization.metric.gridAnchorValue" = "Use as a grid anchor";
"analysis.photoOptimization.metric.gridAnchorDetail" = "Grid anchor means the photo can stabilize the feed visually. Place it near a lifestyle, outfit, or brighter image so the profile alternates between face clarity and context. Too many similar close-ups in a row can feel repetitive.";
"analysis.photoOptimization.metric.storyReplyTriggerValue" = "Needs a reply cue";
"analysis.photoOptimization.metric.storyReplyTriggerDetail" = "A story reply trigger gives followers an easy reason to react. Use a location tag, tiny question, food, music, outfit, or behind-the-scenes cue without covering the face. Keep the text short and let the image carry the mood.";
"analysis.photoOptimization.metric.carouselUseValue" = "Works as first slide";
"analysis.photoOptimization.metric.carouselUseDetail" = "Carousel use checks whether this photo should lead or support a multi-photo post. A clear face can be a strong first slide if the next frames add place, outfit, or movement. Avoid following it with another nearly identical crop.";
"analysis.photoOptimization.metric.postingRhythmValue" = "Pair with brighter context";
"analysis.photoOptimization.metric.postingRhythmDetail" = "Posting rhythm looks at how this image fits before and after nearby posts. If the photo is calm, place it beside something brighter or more active. This keeps the grid from feeling flat while preserving the clean profile read.";
"analysis.photoOptimization.metric.filterRiskValue" = "Avoid heavy edits";
"analysis.photoOptimization.metric.filterRiskDetail" = "Filter risk flags edits that could make the photo feel less real. Heavy smoothing, extreme color shifts, or dark contrast can reduce trust and face clarity. Crop and exposure usually improve this image more than a dramatic filter.";
"analysis.photoOptimization.action.bestPhotoThumbnail" = "Run a tiny thumbnail test before choosing the winner; the best photo should still show eyes, face shape, and mood when it is very small.";
"analysis.photoOptimization.action.bestPhotoExpression" = "Retake the leading photo with the same crop but a slightly warmer half-smile, then compare whether it feels more approachable without looking forced.";
"analysis.photoOptimization.action.bestPhotoBackground" = "Clean one distracting background element or crop tighter so the face wins the frame faster.";
"analysis.photoOptimization.action.bestPhotoFinalCheck" = "Do not pick the most stylish photo if the face reads slower; the lead image should win the first second.";
"analysis.photoOptimization.action.bestAngleSequence" = "Shoot a quick comparison set: front, left three-quarter, and right three-quarter under the same light before deciding the final angle.";
"analysis.photoOptimization.action.bestAngleLensHeight" = "Keep the lens at eye level or slightly above; low close-ups usually pull attention away from the eyes.";
"analysis.photoOptimization.action.bestAngleChinShoulder" = "Keep the chin neutral and drop the near shoulder slightly so the angle looks natural instead of stiff.";
"analysis.photoOptimization.action.bestAngleSideChoice" = "Use the side that keeps eye contact while adding jaw and cheekbone separation; avoid turning so far that it becomes a side-profile pose.";
