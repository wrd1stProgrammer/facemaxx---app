"analysis.photoOptimization.metric.bestPickReadiness" = "Meilleur choix de préparation";
"analysis.photoOptimization.metric.bestPickReadinessValue" = "7.4 · Choix principal utilisable";
"analysis.photoOptimization.metric.bestPickReadinessDetail" = "Ceci vérifie si la photo est suffisamment forte pour être utilisée comme image principale. Un bon résultat signifie que le visage est lisible, que la photo semble intentionnelle et qu'il n'y a aucune distraction évidente. Si le score est serré mais pas élite, une reprise plus propre peut généralement le battre.";
"analysis.photoOptimization.metric.faceVisibility" = "Visibilité du visage";
"analysis.photoOptimization.metric.faceVisibilityValue" = "7.6 · Effacer la lecture";
"analysis.photoOptimization.metric.faceVisibilityDetail" = "La visibilité du visage mesure la facilité avec laquelle l'observateur peut lire les yeux, l'expression et le contour du visage. Une forte visibilité rend la photo plus fiable et plus soignée. Gardez le visage dégagé et évitez les cultures qui cachent le contour des yeux.";
"analysis.photoOptimization.metric.expressionWarmth" = "Chaleur d'expression";
"analysis.photoOptimization.metric.expressionWarmthValue" = "6.9 · Légèrement réservé";
"analysis.photoOptimization.metric.expressionWarmthDetail" = "La chaleur de l'expression vérifie si la photo semble détendue, ouverte et facile à approcher. Une expression neutre peut fonctionner, mais un petit demi-sourire améliore généralement la première lecture. Le but est une présence naturelle, pas un sourire forcé.";
"analysis.photoOptimization.metric.lightingQuality" = "Qualité de l'éclairage";
"analysis.photoOptimization.metric.lightingQualityValue" = "7.1 · Solide, améliorable";
"analysis.photoOptimization.metric.lightingQualityDetail" = "La qualité de l'éclairage mesure la manière dont le visage est éclairé de manière uniforme et si les ombres aident ou nuisent à la structure. La lumière frontale douce rend généralement la peau, les yeux et la symétrie plus propres. Évitez les éclairages intenses au plafond ou les ombres latérales sombres pour les photos utilisant le profil.";
"analysis.photoOptimization.metric.composition" = "Composition";
"analysis.photoOptimization.metric.compositionValue" = "7.2 · Bien cadré";
"analysis.photoOptimization.metric.compositionDetail" = "La composition vérifie le recadrage, la position de la tête et l'équilibre visuel autour du visage. Une composition forte maintient l'attention sur le visage sans se sentir à l'étroit. Laissez suffisamment d’espace autour de la tête et gardez les yeux près du tiers supérieur.";
"analysis.photoOptimization.metric.backgroundControl" = "Contrôle d'arrière-plan";
"analysis.photoOptimization.metric.backgroundControlValue" = "6.8 · Nécessite un nettoyage";
"analysis.photoOptimization.metric.backgroundControlDetail" = "Le contrôle de l'arrière-plan mesure si le paramètre prend en charge la photo ou est en concurrence avec le visage. Des arrière-plans simples et épurés donnent à l’image entière une impression de qualité supérieure. Supprimez le désordre, les objets lumineux et les lignes gênantes près de la tête.";
"analysis.photoOptimization.metric.winningMove" = "Coup gagnant";
"analysis.photoOptimization.metric.winningMoveValue" = "Reprise avec un éclairage avant plus doux";
"analysis.photoOptimization.metric.winningMoveDetail" = "Le mouvement gagnant est le changement ayant le plus grand impact pour la prochaine version de la photo. Dans la plupart des cas, un meilleur éclairage et un recadrage plus propre améliorent davantage le résultat qu'une retouche lourde. Apportez un changement clair, puis comparez avec cette image.";
"analysis.photoOptimization.metric.retakeLight" = "Reprendre la lumière";
"analysis.photoOptimization.metric.retakeLightValue" = "Éclairage de fenêtre avant gauche";
"analysis.photoOptimization.metric.retakeLightDetail" = "Retake light définit la configuration d'éclairage la plus utile pour la prochaine version. La lumière douce de la fenêtre avant ajoute des projecteurs et maintient la texture de la peau plus propre sans aplatir le visage. Gardez le téléphone stable et évitez les éclairages puissants.";
"analysis.photoOptimization.metric.editCleanup" = "Modifier le nettoyage";
"analysis.photoOptimization.metric.editCleanupValue" = "Réduire les distractions en arrière-plan";
"analysis.photoOptimization.metric.editCleanupDetail" = "Le nettoyage des modifications se concentre sur de petites corrections qui donnent à l'image un aspect intentionnel. Un léger flou d'arrière-plan, un recadrage plus serré ou un réglage de l'exposition peuvent améliorer la mise au point sans donner à la photo un aspect surédité. Gardez la texture du visage naturelle.";
"analysis.photoOptimization.metric.bestAngle" = "Meilleur angle";
"analysis.photoOptimization.metric.bestAngleValue" = "Légèrement au-dessus du niveau des yeux";
"analysis.photoOptimization.metric.bestAngleDetail" = "Le meilleur angle identifie la position de la caméra la plus susceptible de flatter la structure actuelle du visage. Un petit réglage de la hauteur peut aiguiser la mâchoire, réduire la distorsion et garder les yeux lisibles. Reprenez plusieurs images à la même distance avant de changer d'expression.";
"analysis.photoOptimization.metric.frontRead" = "Lecture avant";
"analysis.photoOptimization.metric.frontReadValue" = "7.3 · Stable";
"analysis.photoOptimization.metric.frontReadDetail" = "La lecture frontale vérifie l'équilibre du visage dans une prise de vue directe face à la caméra. Une lecture frontale stable est utile pour les photos de profil claires et les recadrages de style ID. Gardez le téléphone droit et évitez l'inclinaison de l'objectif qui étire le bas du visage.";
"analysis.photoOptimization.metric.leftRead" = "Lecture côté gauche";
"analysis.photoOptimization.metric.leftReadValue" = "7.1 · Cela vaut la peine d'être testé";
"analysis.photoOptimization.metric.leftReadDetail" = "La lecture du côté gauche estime la façon dont le visage peut se présenter après un léger virage à gauche. Cet angle peut ajouter de la structure lorsque la vue de face semble plate. Testez d'abord un petit virage plutôt qu'un profil latéral spectaculaire.";
"analysis.photoOptimization.metric.rightRead" = "Lecture du côté droit";
"analysis.photoOptimization.metric.rightReadValue" = "7.0 · Cela vaut la peine d'être testé";
"analysis.photoOptimization.metric.rightReadDetail" = "La lecture du côté droit estime la façon dont le visage peut se présenter après un léger virage à droite. Il est utile pour trouver le côté qui donne une meilleure définition de la mâchoire et des joues. Comparez-le sous la même lumière pour que l'angle soit la seule variable.";
"analysis.photoOptimization.metric.cameraHeight" = "Hauteur de la caméra";
"analysis.photoOptimization.metric.cameraHeightValue" = "Niveau des yeux trop élevé";
"analysis.photoOptimization.metric.cameraHeightDetail" = "La hauteur de la caméra affecte la mâchoire, le front et le milieu du visage plus que ce à quoi la plupart des gens s'attendent. Le niveau des yeux ou légèrement au-dessus permet généralement de conserver des proportions naturelles tout en améliorant le contour du visage. Évitez de prendre des photos sous le menton pour les photos de profil principales.";
"analysis.photoOptimization.metric.avoidAngle" = "Angle à éviter";
"analysis.photoOptimization.metric.avoidAngleValue" = "Angle de selfie faible et rapproché";
"analysis.photoOptimization.metric.avoidAngleDetail" = "Ceci signale la perspective la plus susceptible d'affaiblir la photo. Des angles de gros plan faibles peuvent exagérer le bas du visage, aplatir les yeux et rendre le recadrage décontracté. Reculez, utilisez un zoom léger si disponible et gardez l'objectif plus droit.";
"analysis.photoOptimization.metric.retakePlan" = "Plan de reprise";
"analysis.photoOptimization.metric.retakePlanValue" = "Même pose, configuration plus propre";
"analysis.photoOptimization.metric.retakePlanDetail" = "Un plan de reprise transforme l'analyse en une prochaine prise de vue reproductible. Utilisez une lumière frontale douce, tenez l’appareil photo juste au-dessus du niveau des yeux et prenez plusieurs photos en tournant légèrement la tête. Choisissez la version où les yeux, la mâchoire et l’expression se lisent clairement.";
"analysis.photoOptimization.metric.mainPhotoSuitability" = "Adéquation de la photo principale";
"analysis.photoOptimization.metric.mainPhotoSuitabilityValue" = "7.2 · Bonne sauvegarde";
"analysis.photoOptimization.metric.mainPhotoSuitabilityDetail" = "Cela mesure si l'image peut fonctionner comme première photo d'application de rencontres. La photo principale a besoin de clarté, de chaleur et de suffisamment de personnalité pour arrêter un balayage rapide. Si le visage est clair mais l'énergie est calme, utilisez-la comme sauvegarde ou reprenez avec plus de présence.";
"analysis.photoOptimization.metric.approachability" = "Accessibilité";
"analysis.photoOptimization.metric.approachabilityValue" = "7.0 · Assez convivial";
"analysis.photoOptimization.metric.approachabilityDetail" = "L'accessibilité mesure si la photo semble facile à utiliser. Des yeux plus doux, une posture détendue et un doux sourire peuvent changer rapidement la lecture. Évitez les expressions qui semblent vides, tendues ou trop posées.";
"analysis.photoOptimization.metric.confidenceSignal" = "Signal de confiance";
"analysis.photoOptimization.metric.confidenceSignalValue" = "7.1 · Confiance calme";
"analysis.photoOptimization.metric.confidenceSignalDetail" = "Le signal de confiance provient de la posture, du contact visuel, du cadrage et de l'expression. La version la plus solide semble composée sans paraître raide. Gardez les épaules détendues et regardez à travers l’objectif plutôt que vers l’écran.";
"analysis.photoOptimization.metric.trustSignal" = "Signal de confiance";
"analysis.photoOptimization.metric.trustSignalValue" = "7.3 · Clair et crédible";
"analysis.photoOptimization.metric.trustSignalDetail" = "Le signal de confiance vérifie si l'image semble authentique, actuelle et facile à comprendre. Un éclairage clair et un visage non filtré augmentent généralement ce score. Évitez les modifications lourdes, les yeux cachés et les paramètres qui rendent la photo ambiguë.";
"analysis.photoOptimization.metric.conversationHook" = "Crochet de conversation";
"analysis.photoOptimization.metric.conversationHookValue" = "6.6 · Nécessite un signal plus fort";
"analysis.photoOptimization.metric.conversationHookDetail" = "L'outil de conversation mesure si la photo donne à quelqu'un une raison simple de commenter. Un paramètre, une activité ou un détail de style peut rendre le profil plus mémorable. Gardez le crochet subtil pour qu'il soutienne le visage au lieu de le distraire.";
"analysis.photoOptimization.metric.photoMix" = "Mélange de photos";
"analysis.photoOptimization.metric.photoMixValue" = "Ajouter du contexte et de la variété";
"analysis.photoOptimization.metric.photoMixDetail" = "Le mélange de photos examine ce que cette image devrait faire dans un ensemble de profils plus large. Un ensemble solide comprend généralement une photo de visage claire, une photo de tout le corps ou de style et une image sociale ou d'activité. Cette photo devrait remplir le rôle qu’elle assume le mieux au lieu d’essayer de tout faire.";
"analysis.photoOptimization.metric.avoidProfile" = "Erreur de profil à éviter";
"analysis.photoOptimization.metric.avoidProfileValue" = "Ne dirigez pas avec peu d'énergie";
"analysis.photoOptimization.metric.avoidProfileDetail" = "Ceci signale le choix de profil le plus susceptible de faire baisser les résultats. Évitez de commencer avec une image sombre, plate, trop recadrée ou émotionnellement fermée. La première photo doit rendre le visage et l’ambiance évidents en une seconde.";
"analysis.photoOptimization.metric.profileCrop" = "Recadrage de profil";
"analysis.photoOptimization.metric.profileCropValue" = "7.2 · Miniature lisible";
"analysis.photoOptimization.metric.profileCropDetail" = "Le recadrage du profil mesure si l'image fonctionne toujours lorsqu'elle est réduite à un petit cercle ou un carré. Les yeux et le contour du visage doivent rester lisibles à la taille d'une vignette. Évitez de placer le visage trop bas, trop petit ou trop près d’un bord.";
"analysis.photoOptimization.metric.firstImpression" = "Première impression";
"analysis.photoOptimization.metric.firstImpressionValue" = "7.3 · Nettoyer la première lecture";
"analysis.photoOptimization.metric.firstImpressionDetail" = "La première impression mesure la lecture visuelle immédiate avant que quelqu'un n'étudie les détails. Les premières impressions fortes sont claires, intentionnelles et émotionnellement faciles à situer. Améliorez cela en simplifiant le cadre et en rendant l’expression plus décisive.";
"analysis.photoOptimization.metric.feedFit" = "Ajustement du flux";
"analysis.photoOptimization.metric.feedFitValue" = "7.0 · S'adapte avec du vernis";
"analysis.photoOptimization.metric.feedFitDetail" = "Feed Fit vérifie si l'image s'insérerait naturellement dans une grille Instagram ou un profil social. La couleur, le recadrage, le contraste et le style affectent tous la cohérence du résultat. Utilisez un style d'éclairage cohérent si vous souhaitez que le profil ait l'air organisé.";
"analysis.photoOptimization.metric.storyThumbnail" = "Miniature de l'histoire";
"analysis.photoOptimization.metric.storyThumbnailValue" = "6.9 · Nécessite un cadrage plus audacieux";
"analysis.photoOptimization.metric.storyThumbnailDetail" = "La miniature de l'histoire mesure si l'image reste lisible dans les petits emplacements à visualisation rapide. Un visage clair, un arrière-plan simple et un contraste plus fort aident. Si la photo semble trop subtile, recadrez plus étroitement autour du visage et du haut du corps.";
"analysis.photoOptimization.metric.visualConsistency" = "Cohérence visuelle";
"analysis.photoOptimization.metric.visualConsistencyValue" = "7.1 · Généralement cohérent";
"analysis.photoOptimization.metric.visualConsistencyDetail" = "La cohérence visuelle mesure dans quelle mesure la couleur, la lumière et le style de la photo correspondent à une direction de profil soignée. La cohérence donne au profil un aspect intentionnel plutôt qu’aléatoire. Choisissez une ambiance lumineuse et répétez-la sur vos meilleures photos.";
"analysis.photoOptimization.metric.captionDirection" = "Direction des sous-titres";
"analysis.photoOptimization.metric.captionDirectionValue" = "Restez simple et précis";
"analysis.photoOptimization.metric.captionDirectionDetail" = "La direction de la légende suggère le ton qui soutient le mieux l'image. Une légende courte et concrète fonctionne généralement mieux que de surexpliquer la photo. Faites correspondre la légende au décor, à l'ambiance ou à l'activité visible.";
"analysis.photoOptimization.metric.postingFix" = "Correction de publication";
"analysis.photoOptimization.metric.postingFixValue" = "Nettoyeur de récolte avant la publication";
"analysis.photoOptimization.metric.postingFixDetail" = "Le correctif de publication est la modification la plus rapide avant la mise en ligne de l'image. Améliorez le recadrage, réduisez les distractions en arrière-plan et gardez le visage suffisamment lumineux à la taille de l'écran du téléphone. Évitez les filtres qui changent le teint ou rendent les yeux moins clairs.";
"analysis.aestheticsResults.shapes" = "Formes";
"analysis.aestheticsResults.badge.unlocked" = "DÉBLOQUÉ";
"analysis.aestheticsResults.proportions" = "Proportions";
"analysis.aestheticsResults.shape.faceShape" = "Forme du visage";
"analysis.aestheticsResults.shape.faceShapeValue" = "Ovale";
"analysis.aestheticsResults.shape.faceShapeDetail" = "La forme ovale du visage donne à la photo un contour équilibré avec un tiers inférieur légèrement effilé.";
"analysis.aestheticsResults.shape.eyeShape" = "Forme des yeux";
"analysis.aestheticsResults.shape.eyeShapeValue" = "Refusé";
"analysis.aestheticsResults.shape.eyeShapeDetail" = "La forme des yeux baissés se lit comme une ligne des yeux plus douce et plus détendue. Le style peut rehausser visuellement le coin extérieur.";
"analysis.aestheticsResults.shape.eyebrowShape" = "Forme des sourcils";
"analysis.aestheticsResults.shape.eyebrowShapeValue" = "Arc (queue extérieure)";
"analysis.aestheticsResults.shape.eyebrowShapeDetail" = "L'arc externe de la queue ajoute de la structure au-dessus des yeux sans rendre l'expression trop sévère.";
"analysis.aestheticsResults.shape.lipShape" = "Forme des lèvres";
"analysis.aestheticsResults.shape.lipShapeValue" = "Renversé";
"analysis.aestheticsResults.shape.lipShapeDetail" = "La forme des lèvres retroussées donne au bas du visage une expression légèrement plus chaleureuse, même dans une pose neutre.";
"analysis.aestheticsResults.proportion.canthalTilt" = "Inclinaison Canthal";
"analysis.aestheticsResults.proportion.canthalTiltValue" = "6,8°";
"analysis.aestheticsResults.proportion.canthalTiltDetail" = "Angle du coin de l'œil intérieur vers extérieur. Une inclinaison positive peut rendre le contour des yeux plus net et plus alerte.";
"analysis.aestheticsResults.proportion.eyeSpacingRatio" = "Rapport d'espacement des yeux (ESR)";
"analysis.aestheticsResults.proportion.eyeSpacingRatioValue" = "0.46";
"analysis.aestheticsResults.proportion.eyeSpacingRatioDetail" = "Écart entre les yeux par rapport à la largeur des yeux. 0,46 se situe dans une plage équilibrée normale pour cette culture de visage.";
"analysis.aestheticsResults.proportion.faceWidthHeightRatio" = "Rapport largeur-hauteur du visage";
"analysis.aestheticsResults.proportion.faceWidthHeightRatioValue" = "1.71";
"analysis.aestheticsResults.proportion.faceWidthHeightRatioDetail" = "Largeur du visage ÷ hauteur du visage. Idéal ≈ 1,8 à 2,0 pour les hommes et 1,6 à 1,8 pour les femmes. Un fWHR plus élevé, dans la fourchette typique, peut être associé à des perceptions de dominance.";
"analysis.aestheticsResults.proportion.midfaceRatio" = "Rapport médian";
"analysis.aestheticsResults.proportion.midfaceRatioValue" = "0.90";
"analysis.aestheticsResults.proportion.midfaceRatioDetail" = "Hauteur médiane du visage par rapport à la largeur du visage. 0,90 suggère des proportions compactes de tiers moyen dans cette vue.";
"analysis.aestheticsResults.proportion.philtrumToChinRatio" = "Rapport philtrum/menton";
"analysis.aestheticsResults.proportion.philtrumToChinRatioValue" = "1:2.0";
"analysis.aestheticsResults.proportion.philtrumToChinRatioDetail" = "Longueur du philtrum ÷ tiers inférieur de la face. Le rapport 1:2 indique la jeunesse et la proportion. Des valeurs plus élevées peuvent être plus masculines et dominantes.";
"analysis.aestheticsResults.proportion.eyeWidthFaceRatio" = "Rapport largeur des yeux/visage";
"analysis.aestheticsResults.proportion.eyeWidthFaceRatioValue" = "0.23";
"analysis.aestheticsResults.proportion.eyeWidthFaceRatioDetail" = "Largeur des yeux par rapport à la largeur totale du visage. Cette valeur maintient le contour des yeux proportionné sans paraître trop étroit.";
"analysis.aestheticsResults.proportion.upperLipToLowerLip" = "Lèvre supérieure à lèvre inférieure";
"analysis.aestheticsResults.proportion.upperLipToLowerLipValue" = "1:1.4";
"analysis.aestheticsResults.proportion.upperLipToLowerLipDetail" = "Lèvre supérieure comparée à la lèvre inférieure. Ce rapport suggère une lèvre inférieure avec un poids visuel légèrement plus fort.";
"analysis.aestheticsResults.proportion.eyeWidthHeightRatio" = "Rapport largeur-hauteur des yeux";
"analysis.aestheticsResults.proportion.eyeWidthHeightRatioValue" = "2.9";
"analysis.aestheticsResults.proportion.eyeWidthHeightRatioDetail" = "Largeur des yeux par rapport à la hauteur des yeux. 2.9 se lit comme une forme d’œil allongée avec une ligne horizontale plus nette.";
"analysis.aestheticsResults.proportion.lowerToFullFaceRatio" = "Rapport face inférieure/face complète";
"analysis.aestheticsResults.proportion.lowerToFullFaceRatioValue" = "0.69";
"analysis.aestheticsResults.proportion.lowerToFullFaceRatioDetail" = "Hauteur de visage inférieure par rapport à la hauteur de visage totale. Cette valeur donne au tiers inférieur une présence perceptible sans dominer le visage.";
"analysis.aestheticsResults.proportion.eyeToMouthAngle" = "Angle œil-bouche";
"analysis.aestheticsResults.proportion.eyeToMouthAngleValue" = "45,7°";
"analysis.aestheticsResults.proportion.eyeToMouthAngleDetail" = "L'angle diagonal œil-bouche permet d'estimer le flux facial. Cette valeur suggère un cadre descendant stable des yeux à la bouche.";
"analysis.aestheticsResults.proportion.faceDepthWidthRatio" = "Rapport profondeur-largeur du visage";
"analysis.aestheticsResults.proportion.faceDepthWidthRatioDetail" = "Profondeur faciale estimée par rapport à la largeur visible, à l'aide du maillage du visage et du contexte de l'image. Une lecture équilibrée profondeur-largeur peut donner au visage un aspect plus dimensionnel sans paraître trop étroit.";
"analysis.aestheticsResults.proportion.faceContourWidthHeightRatio" = "Rapport largeur-hauteur du contour du visage";
"analysis.aestheticsResults.proportion.faceContourWidthHeightRatioDetail" = "Largeur du contour extérieur du visage par rapport à la hauteur. Cela permet de séparer un cadre facial compact, vertical ou plus large de la seule perspective de la caméra.";
"analysis.glowUpCoach.facialAnalysis" = "Analyse faciale";
"analysis.glowUpCoach.needsWork" = "Besoin de travail";
"analysis.glowUpCoach.yourStrengths" = "Vos points forts";
"analysis.glowUpCoach.summary" = "Résumé";
"analysis.glowUpCoach.summaryBody" = "Vous disposez d'une base solide pour un éclat éclatant, avec une peau claire, des traits symétriques et une apparence soignée. Le principal domaine sur lequel se concentrer est de projeter plus de chaleur et de confiance à travers l’expression, l’angle de caméra et des choix de style subtils. Dans l’ensemble, vous vous en sortez déjà très bien. Quelques petites améliorations de présentation peuvent rehausser encore plus votre look.";
"analysis.glowUpCoach.item.symmetry" = "Symétrie";
"analysis.glowUpCoach.item.symmetryAssessment" = "Évaluation : Votre visage apparaît assez symétrique, avec des traits équilibrés des deux côtés et aucun déséquilibre visuel majeur sur cette photo.";
"analysis.glowUpCoach.item.symmetryAction" = "Plan : gardez les photos directement et évitez les éclairages latéraux intenses afin que l'équilibre naturel de votre visage reste clair.";
"analysis.glowUpCoach.item.skin" = "Peau";
"analysis.glowUpCoach.item.skinAssessment" = "Évaluation : Votre peau semble lisse, claire et uniforme, avec un minimum d'imperfections ou de rougeurs. Votre teint retrouve un aspect sain et naturel.";
"analysis.glowUpCoach.item.skinAction" = "Plan : Continuez avec une routine de soins de la peau cohérente : un nettoyant doux, une crème hydratante et un écran solaire quotidiennement. Pour plus d’éclat, pensez à ajouter un sérum hydratant ou un traitement exfoliant hebdomadaire.";
"analysis.glowUpCoach.item.jawline" = "Mâchoire";
"analysis.glowUpCoach.item.jawlineAssessment" = "Évaluation : Votre mâchoire est nette et proportionnée, avec suffisamment de définition pour soutenir le bas du visage sans paraître dure.";
"analysis.glowUpCoach.item.jawlineAction" = "Plan : utilisez un angle de caméra légèrement plus élevé et une posture détendue du cou pour rendre la mâchoire plus nette sur les photos.";
"analysis.glowUpCoach.item.eyeArea" = "Zone des yeux";
"analysis.glowUpCoach.item.eyeAreaAssessment" = "Bilan : Votre contour des yeux présente un aspect apaisé et équilibré. L’expression actuelle est neutre, ce qui rend le regard réservé.";
"analysis.glowUpCoach.item.eyeAreaAction" = "Plan : Rehaussez doucement l'expression avec un éclairage plus vif et un sourcil subtilement relevé pour donner l'impression que les yeux sont plus ouverts.";
"analysis.glowUpCoach.item.cheekbones" = "Pommettes";
"analysis.glowUpCoach.item.cheekbonesAssessment" = "Évaluation : La structure des pommettes est visible et soutient le milieu du visage, en particulier lorsque la lumière arrive de face.";
"analysis.glowUpCoach.item.cheekbonesAction" = "Plan : utilisez un éclairage directionnel doux et évitez les plafonniers plats pour montrer davantage la dimension du visage.";
"analysis.glowUpCoach.item.eyebrows" = "Sourcils";
"analysis.glowUpCoach.item.eyebrowsAssessment" = "Évaluation : Vos sourcils encadrent bien le contour des yeux et ajoutent de la structure, mais les bords pourraient être plus nets sur des photos rapprochées.";
"analysis.glowUpCoach.item.eyebrowsAction" = "Plan : un toilettage léger autour des poils errants peut affiner le contour des yeux sans modifier la forme naturelle de vos sourcils.";
"analysis.glowUpCoach.item.glow" = "Lueur";
"analysis.glowUpCoach.item.glowAssessment" = "Bilan : L'éclat général est solide, avec une peau nette et une structure équilibrée. Le principal limiteur est l’énergie photo plutôt que les traits du visage.";
"analysis.glowUpCoach.item.glowAction" = "Plan : Améliorez l'éclairage, la posture et l'expression de l'avant. Ces changements créent l’éclat visible le plus rapide sur les photos.";
"analysis.glowUpCoach.item.hair" = "Cheveux";
"analysis.glowUpCoach.item.hairAssessment" = "Bilan : Vos cheveux épousent la forme du visage et ajoutent du volume autour du tiers supérieur.";
"analysis.glowUpCoach.item.hairAction" = "Plan : Gardez le dessus texturé et contrôlé. Une frange plus propre ou un flux latéral peut ouvrir le front et le contour des yeux.";
"analysis.glowUpCoach.item.confidence" = "Confiance";
"analysis.glowUpCoach.item.confidenceAssessment" = "Évaluation : L'expression neutre donne à la photo une impression de calme mais légèrement réservée.";
"analysis.glowUpCoach.item.confidenceAction" = "Plan : pratiquez un demi-sourire détendu et testez des angles qui vous donnent l'air plus présent et plus confiant.";
"analysis.glowUpCoach.item.expressionConfidence" = "Expression/Confiance";
"analysis.glowUpCoach.item.expressionConfidenceAssessment" = "Évaluation : une expression neutre peut donner une impression de calme, mais elle peut également donner à la photo un aspect réservé ou moins accessible.";
"analysis.glowUpCoach.item.expressionConfidenceAction" = "Plan : pratiquez un demi-sourire détendu, levez légèrement les yeux et comparez quelques angles pour que l'expression soit plus chaleureuse sans avoir l'air forcé.";
"analysis.glowUpCoach.item.faceWidthHeightRatio" = "Rapport longueur/largeur du visage";
"analysis.glowUpCoach.item.faceWidthHeightRatioAssessment" = "Évaluation : la relation entre la longueur et la largeur du visage visible affecte si le visage est compact, allongé ou équilibré sur une photo de face.";
"analysis.glowUpCoach.item.faceWidthHeightRatioAction" = "Plan : utilisez un angle d'objectif droit, gardez l'appareil photo près du niveau des yeux et évitez les distorsions extrêmes en gros plan afin que le cadre naturel du visage soit lu avec précision.";
"analysis.glowUpCoach.item.cameraAngle" = "Angle de la caméra";
"analysis.glowUpCoach.item.cameraAngleAssessment" = "Évaluation : la hauteur et l'inclinaison de la caméra peuvent modifier l'apparence des proportions de la mâchoire, du milieu du visage et du front, même lorsque les caractéristiques sous-jacentes sont équilibrées.";
"analysis.glowUpCoach.item.cameraAngleAction" = "Plan : photographiez à hauteur des yeux ou légèrement au-dessus, gardez la tête centrée et évitez d'incliner le téléphone vers le haut depuis le dessous du menton.";
"analysis.glowUpCoach.item.lighting" = "Éclairage";
"analysis.glowUpCoach.item.lightingAssessment" = "Évaluation : Un éclairage inégal ou zénithal peut aplatir la texture de la peau, exagérer les ombres et rendre la symétrie plus difficile à lire.";
"analysis.glowUpCoach.item.lightingAction" = "Plan : faites face à une grande fenêtre ou à une lumière frontale douce, puis reprenez la photo sans ombres trop prononcées sur les yeux ou le bas du visage.";
"analysis.glowUpCoach.item.grooming" = "Toilettage";
"analysis.glowUpCoach.item.groomingAssessment" = "Évaluation : de petits détails de toilettage autour des sourcils, des bords des cheveux et de la pilosité faciale peuvent modifier le degré de finition de l'ensemble du visage.";
"analysis.glowUpCoach.item.groomingAction" = "Plan : nettoyez d'abord uniquement les bords parasites, conservez la forme naturelle et comparez le résultat sous le même éclairage avant d'apporter des modifications plus importantes.";
"analysis.glowUpCoach.item.photoPresence" = "Photo de présence";
"analysis.glowUpCoach.item.photoPresenceAssessment" = "Évaluation : la posture, le contact visuel et l'expression déterminent si des traits forts se traduisent par une photo confiante.";
"analysis.glowUpCoach.item.photoPresenceAction" = "Plan : allongez le cou, détendez les épaules, regardez directement à travers l'objectif et prenez plusieurs photos avec un petit changement d'expression.";
"analysis.glowUpCoach.item.skinQuality" = "Qualité de la peau";
"analysis.glowUpCoach.item.skinQualityAssessment" = "Évaluation : la qualité de votre peau est l'un des éléments les plus importants de ce scan, avec un ton net et un minimum de problèmes de texture visibles.";
"analysis.glowUpCoach.item.skinQualityAction" = "Plan : continuez à protéger cet avantage avec un écran solaire quotidien, une hydratation et un sommeil constant.";
"analysis.glowUpCoach.item.harmony" = "Harmonie";
