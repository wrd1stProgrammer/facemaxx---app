"analysis.photoOptimization.metric.backgroundControl" = "Kontrol Latar Belakang";
"analysis.photoOptimization.metric.backgroundControlValue" = "6.8 · Perlu pembersihan";
"analysis.photoOptimization.metric.backgroundControlDetail" = "Kontrol latar belakang mengukur apakah pengaturan mendukung foto atau bersaing dengan wajah. Latar belakang yang sederhana dan bersih membuat keseluruhan gambar terasa lebih premium. Singkirkan kekacauan, benda terang, dan garis-garis aneh di dekat kepala.";
"analysis.photoOptimization.metric.winningMove" = "Langkah Kemenangan";
"analysis.photoOptimization.metric.winningMoveValue" = "Ambil ulang dengan lampu depan yang lebih lembut";
"analysis.photoOptimization.metric.winningMoveDetail" = "Langkah yang menang adalah satu-satunya perubahan dengan dampak tertinggi untuk versi foto berikutnya. Dalam kebanyakan kasus, pemotongan yang lebih terang dan lebih bersih meningkatkan hasil lebih dari pengeditan berat. Buat satu perubahan yang jelas, lalu bandingkan dengan gambar ini.";
"analysis.photoOptimization.metric.retakeLight" = "Ambil Ulang Cahaya";
"analysis.photoOptimization.metric.retakeLightValue" = "Lampu jendela dari kiri depan";
"analysis.photoOptimization.metric.retakeLightDetail" = "Lampu pengambilan ulang menentukan pengaturan pencahayaan yang paling berguna untuk versi berikutnya. Cahaya jendela sisi depan yang lembut menambah cahaya tangkapan dan menjaga tekstur kulit lebih bersih tanpa membuat wajah rata. Jaga agar ponsel tetap stabil dan hindari cahaya terang di atas kepala.";
"analysis.photoOptimization.metric.editCleanup" = "Edit Pembersihan";
"analysis.photoOptimization.metric.editCleanupValue" = "Kurangi gangguan di latar belakang";
"analysis.photoOptimization.metric.editCleanupDetail" = "Pembersihan pengeditan berfokus pada koreksi kecil yang membuat gambar terasa disengaja. Latar belakang yang sedikit buram, pemotongan yang lebih ketat, atau penyesuaian pencahayaan dapat meningkatkan fokus tanpa membuat foto terlihat diedit secara berlebihan. Jaga tekstur wajah tetap alami.";
"analysis.photoOptimization.metric.bestAngle" = "Sudut Terbaik";
"analysis.photoOptimization.metric.bestAngleValue" = "Sedikit di atas ketinggian mata";
"analysis.photoOptimization.metric.bestAngleDetail" = "Sudut terbaik mengidentifikasi posisi kamera yang paling mungkin menyanjung struktur wajah saat ini. Penyesuaian ketinggian kecil dapat mempertajam rahang, mengurangi distorsi, dan menjaga mata tetap terbaca. Ambil kembali beberapa frame dari jarak yang sama sebelum mengubah ekspresi.";
"analysis.photoOptimization.metric.frontRead" = "Bacaan Depan";
"analysis.photoOptimization.metric.frontReadValue" = "7.3 · Stabil";
"analysis.photoOptimization.metric.frontReadDetail" = "Pembacaan depan memeriksa seberapa seimbang tampilan wajah dalam bidikan menghadap kamera langsung. Pembacaan depan yang stabil berguna untuk foto profil yang jelas dan pemotongan bergaya ID. Jaga agar ponsel tetap lurus dan hindari kemiringan lensa yang meregangkan bagian bawah wajah.";
"analysis.photoOptimization.metric.leftRead" = "Bacaan Sisi Kiri";
"analysis.photoOptimization.metric.leftReadValue" = "7.1 · Layak untuk diuji";
"analysis.photoOptimization.metric.leftReadDetail" = "Pembacaan sisi kiri memperkirakan tampilan wajah jika sedikit berbelok ke kiri. Sudut ini dapat menambah struktur ketika tampilan depan terasa datar. Ujilah belokan kecil terlebih dahulu daripada profil samping yang dramatis.";
"analysis.photoOptimization.metric.rightRead" = "Bacaan Sisi Kanan";
"analysis.photoOptimization.metric.rightReadValue" = "7.0 · Layak untuk diuji";
"analysis.photoOptimization.metric.rightReadDetail" = "Pembacaan sisi kanan memperkirakan tampilan wajah jika sedikit berbelok ke kanan. Hal ini berguna untuk menemukan sisi yang memberikan definisi rahang dan pipi yang lebih baik. Bandingkan di bawah cahaya yang sama sehingga sudutnya adalah satu-satunya variabel.";
"analysis.photoOptimization.metric.cameraHeight" = "Tinggi Kamera";
"analysis.photoOptimization.metric.cameraHeightValue" = "Ketinggian mata agak tinggi";
"analysis.photoOptimization.metric.cameraHeightDetail" = "Ketinggian kamera memengaruhi garis rahang, dahi, dan bagian tengah wajah lebih dari yang diperkirakan kebanyakan orang. Ketinggian mata atau sedikit lebih tinggi biasanya menjaga proporsi tetap alami sekaligus memperbaiki garis wajah. Hindari memotret dari bawah dagu untuk foto profil utama.";
"analysis.photoOptimization.metric.avoidAngle" = "Sudut yang Harus Dihindari";
"analysis.photoOptimization.metric.avoidAngleValue" = "Sudut selfie rendah dan dekat";
"analysis.photoOptimization.metric.avoidAngleDetail" = "Ini menandai perspektif yang paling mungkin melemahkan foto. Sudut close-up yang rendah dapat menonjolkan bagian bawah wajah, meratakan mata, dan membuat hasil potongan terlihat biasa saja. Mundur, gunakan zoom ringan jika tersedia, dan pertahankan lensa tetap tegak.";
"analysis.photoOptimization.metric.retakePlan" = "Rencana Pengambilan Ulang";
"analysis.photoOptimization.metric.retakePlanValue" = "Pose yang sama, pengaturan yang lebih bersih";
"analysis.photoOptimization.metric.retakePlanDetail" = "Rencana pengambilan ulang mengubah analisis menjadi pengambilan gambar berikutnya yang dapat diulang. Gunakan cahaya depan yang lembut, pegang kamera tepat di atas ketinggian mata, dan ambil beberapa bingkai dengan putaran kepala kecil. Pilih versi yang mata, garis rahang, dan ekspresinya terbaca dengan jelas.";
"analysis.photoOptimization.metric.mainPhotoSuitability" = "Kesesuaian Foto Utama";
"analysis.photoOptimization.metric.mainPhotoSuitabilityValue" = "7.2 · Cadangan yang bagus";
"analysis.photoOptimization.metric.mainPhotoSuitabilityDetail" = "Ini mengukur apakah gambar tersebut dapat berfungsi sebagai foto aplikasi kencan pertama. Foto utama memerlukan kejelasan, kehangatan, dan kepribadian yang cukup untuk menghentikan gesekan cepat. Jika wajah terlihat jelas namun energinya tenang, gunakan sebagai cadangan atau ambil ulang dengan lebih banyak kehadiran.";
"analysis.photoOptimization.metric.approachability" = "Kemudahan untuk didekati";
"analysis.photoOptimization.metric.approachabilityValue" = "7.0 · Cukup ramah";
"analysis.photoOptimization.metric.approachabilityDetail" = "Kemudahan untuk didekati mengukur apakah foto terasa mudah untuk dilibatkan. Mata yang lebih lembut, postur tubuh yang rileks, dan senyuman yang lembut dapat mengubah bacaan dengan cepat. Hindari ekspresi yang terkesan kosong, tegang, atau berlebihan.";
"analysis.photoOptimization.metric.confidenceSignal" = "Sinyal Keyakinan";
"analysis.photoOptimization.metric.confidenceSignalValue" = "7.1 · Percaya diri yang tenang";
"analysis.photoOptimization.metric.confidenceSignalDetail" = "Sinyal percaya diri datang dari postur, kontak mata, framing, dan ekspresi. Versi terkuat terasa tenang tanpa terlihat kaku. Jaga agar bahu tetap rileks dan lihat melalui lensa, bukan ke layar.";
"analysis.photoOptimization.metric.trustSignal" = "Sinyal Kepercayaan";
"analysis.photoOptimization.metric.trustSignalValue" = "7.3 · Jelas dan kredibel";
"analysis.photoOptimization.metric.trustSignalDetail" = "Sinyal kepercayaan memeriksa apakah gambar terasa autentik, terkini, dan mudah dipahami. Pencahayaan yang jelas dan wajah tanpa filter biasanya meningkatkan skor ini. Hindari pengeditan yang berat, pandangan tersembunyi, dan pengaturan yang membuat foto terasa ambigu.";
"analysis.photoOptimization.metric.conversationHook" = "Kait Percakapan";
"analysis.photoOptimization.metric.conversationHookValue" = "6.6 · Membutuhkan isyarat yang lebih kuat";
"analysis.photoOptimization.metric.conversationHookDetail" = "Kait percakapan mengukur apakah foto memberikan alasan yang mudah bagi seseorang untuk berkomentar. Detail pengaturan, aktivitas, atau gaya dapat membuat profil terasa lebih berkesan. Usahakan pengaitnya halus sehingga menopang wajah alih-alih mengganggunya.";
"analysis.photoOptimization.metric.photoMix" = "Campuran Foto";
"analysis.photoOptimization.metric.photoMixValue" = "Tambahkan konteks dan variasi";
"analysis.photoOptimization.metric.photoMixDetail" = "Campuran foto melihat apa yang seharusnya dilakukan gambar ini dalam kumpulan profil yang lebih luas. Kumpulan yang kuat biasanya mencakup satu foto wajah yang jelas, satu foto seluruh tubuh atau gaya, dan satu gambar sosial atau aktivitas. Foto ini harus memenuhi peran yang paling baik ditanganinya daripada mencoba melakukan semuanya.";
"analysis.photoOptimization.metric.avoidProfile" = "Kesalahan Profil yang Harus Dihindari";
"analysis.photoOptimization.metric.avoidProfileValue" = "Jangan memimpin dengan energi rendah";
"analysis.photoOptimization.metric.avoidProfileDetail" = "Ini menandai pilihan profil yang paling mungkin menurunkan hasil. Hindari memimpin dengan gambaran yang suram, datar, terlalu terpotong, atau tertutup secara emosional. Foto pertama akan membuat wajah dan getarannya terlihat jelas dalam satu detik.";
"analysis.photoOptimization.metric.profileCrop" = "Pangkas Profil";
"analysis.photoOptimization.metric.profileCropValue" = "7.2 · Gambar kecil dapat dibaca";
"analysis.photoOptimization.metric.profileCropDetail" = "Pemotongan profil mengukur apakah gambar masih berfungsi saat diperkecil menjadi lingkaran kecil atau persegi. Garis mata dan wajah harus tetap dapat dibaca pada ukuran thumbnail. Hindari menempatkan wajah terlalu rendah, terlalu kecil, atau terlalu dekat dengan tepian.";
"analysis.photoOptimization.metric.firstImpression" = "Kesan Pertama";
"analysis.photoOptimization.metric.firstImpressionValue" = "7.3 · Bersihkan bacaan pertama";
"analysis.photoOptimization.metric.firstImpressionDetail" = "Kesan pertama mengukur pembacaan visual langsung sebelum seseorang mempelajari detailnya. Kesan pertama yang kuat jelas, disengaja, dan mudah diterapkan secara emosional. Perbaiki ini dengan menyederhanakan bingkai dan membuat ekspresi lebih tegas.";
"analysis.photoOptimization.metric.feedFit" = "Umpan Sesuai";
"analysis.photoOptimization.metric.feedFitValue" = "7.0 · Cocok dengan semir";
"analysis.photoOptimization.metric.feedFitDetail" = "Kesesuaian umpan memeriksa apakah gambar akan ditempatkan secara alami di kisi Instagram atau profil sosial. Warna, potongan, kontras, dan gaya semuanya memengaruhi kesan kohesif. Gunakan gaya pencahayaan yang konsisten jika Anda ingin profil terlihat terkurasi.";
"analysis.photoOptimization.metric.storyThumbnail" = "Gambar Kecil Cerita";
"analysis.photoOptimization.metric.storyThumbnailValue" = "6.9 · Membutuhkan pembingkaian yang lebih berani";
"analysis.photoOptimization.metric.storyThumbnailDetail" = "Thumbnail cerita mengukur apakah gambar tetap dapat dibaca di penempatan kecil dan cepat dilihat. Wajah yang jernih, latar belakang yang sederhana, dan kontras yang lebih kuat membantu. Jika foto terasa terlalu halus, potong lebih rapat di sekitar wajah dan tubuh bagian atas.";
"analysis.photoOptimization.metric.visualConsistency" = "Konsistensi Visual";
"analysis.photoOptimization.metric.visualConsistencyValue" = "7.1 · Sebagian besar kohesif";
"analysis.photoOptimization.metric.visualConsistencyDetail" = "Konsistensi visual mengukur seberapa cocok warna, cahaya, dan gaya foto dengan arah profil yang dipoles. Konsistensi membuat profil terasa disengaja, bukan acak. Pilih satu suasana pencahayaan dan ulangi pada foto terbaik Anda.";
"analysis.photoOptimization.metric.captionDirection" = "Arah Teks";
"analysis.photoOptimization.metric.captionDirectionValue" = "Tetap sederhana dan spesifik";
"analysis.photoOptimization.metric.captionDirectionDetail" = "Arah teks menyarankan nada yang paling mendukung gambar. Keterangan singkat dan konkret biasanya lebih baik daripada menjelaskan foto secara berlebihan. Cocokkan keterangan dengan latar, suasana hati, atau aktivitas yang terlihat.";
"analysis.photoOptimization.metric.postingFix" = "Perbaikan Postingan";
"analysis.photoOptimization.metric.postingFixValue" = "Pembersih pangkas sebelum diposting";
"analysis.photoOptimization.metric.postingFixDetail" = "Perbaikan postingan adalah pengeditan tercepat sebelum gambar ditayangkan. Tingkatkan pemangkasan, kurangi gangguan latar belakang, dan pertahankan kecerahan wajah pada ukuran layar ponsel. Hindari filter yang mengubah warna kulit atau membuat mata menjadi kurang jernih.";
"analysis.aestheticsResults.shapes" = "Bentuk";
"analysis.aestheticsResults.badge.unlocked" = "TIDAK TERKUNCI";
"analysis.aestheticsResults.proportions" = "Proporsi";
"analysis.aestheticsResults.shape.faceShape" = "Bentuk Wajah";
"analysis.aestheticsResults.shape.faceShapeValue" = "berbentuk oval";
"analysis.aestheticsResults.shape.faceShapeDetail" = "Bentuk wajah oval memberi foto garis tepi yang seimbang dengan sepertiga bagian bawah yang meruncing lembut.";
"analysis.aestheticsResults.shape.eyeShape" = "Bentuk Mata";
"analysis.aestheticsResults.shape.eyeShapeValue" = "Menurun";
"analysis.aestheticsResults.shape.eyeShapeDetail" = "Bentuk mata yang menurun terlihat seperti garis mata yang lebih lembut dan rileks. Styling dapat mengangkat sudut luar secara visual.";
"analysis.aestheticsResults.shape.eyebrowShape" = "Bentuk Alis";
"analysis.aestheticsResults.shape.eyebrowShapeValue" = "Lengkungan (Ekor luar)";
"analysis.aestheticsResults.shape.eyebrowShapeDetail" = "Lengkungan ekor luar menambah struktur di atas mata tanpa membuat ekspresi terlihat terlalu parah.";
"analysis.aestheticsResults.shape.lipShape" = "Bentuk Bibir";
"analysis.aestheticsResults.shape.lipShapeValue" = "Terbalik";
"analysis.aestheticsResults.shape.lipShapeDetail" = "Bentuk bibir yang menghadap ke atas memberikan ekspresi wajah bagian bawah sedikit lebih hangat bahkan dalam pose netral.";
"analysis.aestheticsResults.proportion.canthalTilt" = "Kemiringan Canthal";
"analysis.aestheticsResults.proportion.canthalTiltValue" = "6,8°";
"analysis.aestheticsResults.proportion.canthalTiltDetail" = "Sudut sudut mata dalam ke luar. Kemiringan positif dapat membuat area mata terbaca lebih tajam dan waspada.";
"analysis.aestheticsResults.proportion.eyeSpacingRatio" = "Rasio Jarak Mata (ESR)";
"analysis.aestheticsResults.proportion.eyeSpacingRatioValue" = "0.46";
"analysis.aestheticsResults.proportion.eyeSpacingRatioDetail" = "Celah mata dibandingkan dengan lebar mata. 0,46 berada dalam kisaran seimbang normal untuk tanaman wajah ini.";
"analysis.aestheticsResults.proportion.faceWidthHeightRatio" = "Rasio Lebar-Tinggi Wajah";
"analysis.aestheticsResults.proportion.faceWidthHeightRatioValue" = "1.71";
"analysis.aestheticsResults.proportion.faceWidthHeightRatioDetail" = "Lebar wajah ± tinggi wajah. Ideal ≈ 1,8 hingga 2,0 untuk pria dan 1,6 hingga 1,8 untuk wanita. Nilai fWHR yang lebih tinggi, dalam rentang tipikal, dapat dikaitkan dengan persepsi dominasi.";
"analysis.aestheticsResults.proportion.midfaceRatio" = "Rasio Bagian Tengah";
"analysis.aestheticsResults.proportion.midfaceRatioValue" = "0.90";
"analysis.aestheticsResults.proportion.midfaceRatioDetail" = "Tinggi bagian tengah wajah dibandingkan dengan lebar wajah. 0,90 menunjukkan proporsi sepertiga menengah yang kompak dalam pandangan ini.";
"analysis.aestheticsResults.proportion.philtrumToChinRatio" = "Rasio Philtrum terhadap Dagu";
"analysis.aestheticsResults.proportion.philtrumToChinRatioValue" = "1:2.0";
"analysis.aestheticsResults.proportion.philtrumToChinRatioDetail" = "Panjang filtrum sepertiga bagian bawah wajah. Rasio 1:2 menunjukkan keremajaan dan proporsi. Nilai yang lebih tinggi bisa dibaca lebih maskulin dan dominan.";
"analysis.aestheticsResults.proportion.eyeWidthFaceRatio" = "Rasio Lebar Mata dan Wajah";
"analysis.aestheticsResults.proportion.eyeWidthFaceRatioValue" = "0.23";
"analysis.aestheticsResults.proportion.eyeWidthFaceRatioDetail" = "Lebar mata dibandingkan dengan total lebar wajah. Nilai ini menjaga area mata tetap proporsional tanpa terlihat terlalu sempit.";
"analysis.aestheticsResults.proportion.upperLipToLowerLip" = "Bibir Atas ke Bibir Bawah";
"analysis.aestheticsResults.proportion.upperLipToLowerLipValue" = "1:1.4";
"analysis.aestheticsResults.proportion.upperLipToLowerLipDetail" = "Bibir atas dibandingkan dengan bibir bawah. Rasio ini menunjukkan bibir bawah dengan bobot visual yang sedikit lebih kuat.";
"analysis.aestheticsResults.proportion.eyeWidthHeightRatio" = "Rasio Lebar-Tinggi Mata";
"analysis.aestheticsResults.proportion.eyeWidthHeightRatioValue" = "2.9";
"analysis.aestheticsResults.proportion.eyeWidthHeightRatioDetail" = "Lebar mata dibandingkan dengan tinggi mata. 2.9 dibaca sebagai bentuk mata memanjang dengan garis horizontal yang lebih bersih.";
"analysis.aestheticsResults.proportion.lowerToFullFaceRatio" = "Rasio Lebih Rendah ke Wajah Penuh";
"analysis.aestheticsResults.proportion.lowerToFullFaceRatioValue" = "0.69";
"analysis.aestheticsResults.proportion.lowerToFullFaceRatioDetail" = "Tinggi wajah lebih rendah dibandingkan tinggi wajah penuh. Nilai ini memberikan sepertiga bagian bawah kehadiran yang nyata tanpa mengganggu wajah.";
"analysis.aestheticsResults.proportion.eyeToMouthAngle" = "Sudut Mata ke Mulut";
"analysis.aestheticsResults.proportion.eyeToMouthAngleValue" = "45,7°";
"analysis.aestheticsResults.proportion.eyeToMouthAngleDetail" = "Sudut diagonal mata-ke-mulut membantu memperkirakan aliran wajah. Nilai ini menunjukkan kerangka ke bawah yang stabil dari mata hingga mulut.";
"analysis.aestheticsResults.proportion.faceDepthWidthRatio" = "Rasio Kedalaman-Lebar Wajah";
"analysis.aestheticsResults.proportion.faceDepthWidthRatioDetail" = "Perkiraan kedalaman wajah dibandingkan dengan lebar tampak, menggunakan mesh wajah dan konteks gambar. Pembacaan kedalaman-ke-lebar yang seimbang dapat membuat wajah terlihat lebih berdimensi tanpa terlihat terlalu sempit.";
"analysis.aestheticsResults.proportion.faceContourWidthHeightRatio" = "Rasio Lebar-Tinggi Kontur Wajah";
"analysis.aestheticsResults.proportion.faceContourWidthHeightRatioDetail" = "Lebar kontur wajah luar dibandingkan dengan tinggi. Ini membantu memisahkan bingkai wajah yang ringkas, vertikal, atau lebih lebar hanya dari sudut pandang kamera.";
"analysis.glowUpCoach.facialAnalysis" = "Analisis Wajah";
"analysis.glowUpCoach.needsWork" = "Perlu Pekerjaan";
"analysis.glowUpCoach.yourStrengths" = "Kekuatan Anda";
"analysis.glowUpCoach.summary" = "Ringkasan";
"analysis.glowUpCoach.summaryBody" = "Anda memiliki dasar yang kuat untuk bersinar, dengan kulit bersih, fitur simetris, dan penampilan rapi. Area utama yang menjadi fokus adalah menampilkan lebih banyak kehangatan dan kepercayaan diri melalui ekspresi, sudut kamera, dan pilihan gaya yang halus. Secara keseluruhan, Anda sudah melakukannya dengan baik. Beberapa peningkatan kecil pada presentasi dapat meningkatkan penampilan Anda lebih jauh lagi.";
"analysis.glowUpCoach.item.symmetry" = "Simetri";
"analysis.glowUpCoach.item.symmetryAssessment" = "Penilaian: Wajah Anda tampak cukup simetris, dengan fitur seimbang di kedua sisi dan tidak ada ketidakseimbangan visual yang besar di foto ini.";
"analysis.glowUpCoach.item.symmetryAction" = "Rencana: Jaga foto tetap lurus dan hindari pencahayaan samping yang kuat agar keseimbangan alami wajah Anda tetap jelas.";
"analysis.glowUpCoach.item.skin" = "Kulit";
"analysis.glowUpCoach.item.skinAssessment" = "Penilaian: Kulit Anda terlihat halus, jernih, dan warnanya merata dengan sedikit noda atau kemerahan. Ada tampilan yang sehat dan alami pada kulit Anda.";
"analysis.glowUpCoach.item.skinAction" = "Rencana: Lanjutkan dengan rutinitas perawatan kulit yang konsisten: pembersih lembut, pelembab, dan tabir surya setiap hari. Untuk mendapatkan kilau ekstra, pertimbangkan untuk menambahkan serum yang menghidrasi atau perawatan eksfoliasi mingguan.";
"analysis.glowUpCoach.item.jawline" = "Garis rahang";
"analysis.glowUpCoach.item.jawlineAssessment" = "Penilaian: Garis rahang Anda terlihat bersih dan proporsional, dengan definisi yang cukup untuk menopang wajah bagian bawah tanpa terlihat kasar.";
"analysis.glowUpCoach.item.jawlineAction" = "Rencana: Gunakan sudut kamera yang sedikit lebih tinggi dan postur leher yang santai untuk membuat garis rahang terlihat lebih tajam di foto.";
"analysis.glowUpCoach.item.eyeArea" = "Area Mata";
"analysis.glowUpCoach.item.eyeAreaAssessment" = "Penilaian: Area mata Anda terlihat tenang dan seimbang. Ekspresinya saat ini netral, yang membuat mata terasa tertutup.";
"analysis.glowUpCoach.item.eyeAreaAction" = "Rencana: Angkat ekspresi secara lembut dengan pencahayaan yang lebih terang dan pengangkatan alis secara halus untuk membuat mata terasa lebih terbuka.";
"analysis.glowUpCoach.item.cheekbones" = "Tulang pipi";
"analysis.glowUpCoach.item.cheekbonesAssessment" = "Penilaian: Struktur tulang pipi terlihat dan menopang bagian tengah wajah, terutama saat cahaya menerpa dari depan.";
"analysis.glowUpCoach.item.cheekbonesAction" = "Rencana: Gunakan pencahayaan terarah lembut dan hindari cahaya datar di atas kepala untuk memperlihatkan lebih banyak dimensi wajah.";
"analysis.glowUpCoach.item.eyebrows" = "Alis";
"analysis.glowUpCoach.item.eyebrowsAssessment" = "Penilaian: Alis Anda membingkai area mata dengan baik dan menambah struktur, namun bagian tepinya dapat terlihat lebih jelas pada foto jarak dekat.";
"analysis.glowUpCoach.item.eyebrowsAction" = "Rencana: Perawatan ringan di sekitar rambut yang tersesat dapat mempertajam area mata tanpa mengubah bentuk alami alis Anda.";
"analysis.glowUpCoach.item.glow" = "Bersinar";
"analysis.glowUpCoach.item.glowAssessment" = "Penilaian: Cahaya keseluruhannya padat, dengan kulit jernih dan struktur seimbang. Pembatas utamanya adalah energi foto, bukan fitur wajah.";
"analysis.glowUpCoach.item.glowAction" = "Rencana: Meningkatkan pencahayaan depan, postur, dan ekspresi. Perubahan ini menciptakan cahaya paling cepat terlihat di foto.";
"analysis.glowUpCoach.item.hair" = "Rambut";
"analysis.glowUpCoach.item.hairAssessment" = "Penilaian: Rambut Anda sesuai dengan bentuk wajah dan menambah volume di sekitar sepertiga bagian atas.";
"analysis.glowUpCoach.item.hairAction" = "Rencana: Jaga agar bagian atas tetap bertekstur dan terkontrol. Pinggiran atau aliran samping yang lebih bersih dapat membuka area dahi dan mata.";
"analysis.glowUpCoach.item.confidence" = "Percaya diri";
"analysis.glowUpCoach.item.confidenceAssessment" = "Penilaian: Ekspresi netral membuat foto terasa tenang namun sedikit pendiam.";
"analysis.glowUpCoach.item.confidenceAction" = "Rencana: Latih setengah senyuman santai dan uji sudut pandang yang membuat Anda terlihat lebih kekinian dan percaya diri.";
"analysis.glowUpCoach.item.expressionConfidence" = "Ekspresi/Percaya Diri";
"analysis.glowUpCoach.item.expressionConfidenceAssessment" = "Penilaian: Ekspresi netral dapat memberikan kesan tenang, namun juga dapat membuat foto terasa tertutup atau kurang mudah didekati.";
"analysis.glowUpCoach.item.expressionConfidenceAction" = "Rencana: Latihlah setengah senyuman santai, angkat sedikit mata, dan bandingkan beberapa sudut agar ekspresi terasa lebih hangat tanpa terlihat dipaksakan.";
"analysis.glowUpCoach.item.faceWidthHeightRatio" = "Rasio Panjang/Lebar Wajah";
"analysis.glowUpCoach.item.faceWidthHeightRatioAssessment" = "Penilaian: Hubungan panjang dan lebar wajah yang terlihat memengaruhi apakah wajah terlihat kompak, memanjang, atau seimbang dalam foto menghadap ke depan.";
"analysis.glowUpCoach.item.faceWidthHeightRatioAction" = "Rencana: Gunakan sudut lensa lurus, jaga kamera tetap dekat dengan ketinggian mata, dan hindari distorsi close-up yang ekstrem sehingga bingkai wajah alami terbaca secara akurat.";
"analysis.glowUpCoach.item.cameraAngle" = "Sudut Kamera";
"analysis.glowUpCoach.item.cameraAngleAssessment" = "Penilaian: Ketinggian dan kemiringan kamera dapat mengubah tampilan proporsi garis rahang, bagian tengah wajah, dan dahi meskipun fitur dasarnya seimbang.";
"analysis.glowUpCoach.item.cameraAngleAction" = "Rencana: Bidik dari ketinggian mata atau sedikit lebih tinggi, jaga agar kepala tetap di tengah, dan hindari memiringkan ponsel ke atas dari bawah dagu.";
"analysis.glowUpCoach.item.lighting" = "Pencahayaan";
"analysis.glowUpCoach.item.lightingAssessment" = "Penilaian: Cahaya yang tidak merata atau di atas kepala dapat meratakan tekstur kulit, memperbesar bayangan, dan membuat simetri lebih sulit dibaca.";
"analysis.glowUpCoach.item.lightingAction" = "Rencana: Hadapi jendela besar atau cahaya depan yang lembut, lalu ambil ulang foto tanpa bayangan atas yang tajam pada mata atau wajah bagian bawah.";
"analysis.glowUpCoach.item.grooming" = "Perawatan";
"analysis.glowUpCoach.item.groomingAssessment" = "Penilaian: Detail perawatan kecil di sekitar alis, tepi rambut, dan bulu wajah dapat mengubah seberapa halus tampilan seluruh wajah.";
"analysis.glowUpCoach.item.groomingAction" = "Rencana: Bersihkan bagian tepinya saja terlebih dahulu, pertahankan bentuk alaminya, dan bandingkan hasilnya dalam pencahayaan yang sama sebelum membuat perubahan yang lebih besar.";
"analysis.glowUpCoach.item.photoPresence" = "Kehadiran Foto";
"analysis.glowUpCoach.item.photoPresenceAssessment" = "Penilaian: Postur tubuh, kontak mata, dan ekspresi menentukan apakah fitur yang kuat diterjemahkan ke dalam foto yang percaya diri.";
"analysis.glowUpCoach.item.photoPresenceAction" = "Rencana: Panjangkan leher, rilekskan bahu, lihat langsung melalui lensa, dan ambil beberapa bingkai dengan sedikit perubahan ekspresi.";
"analysis.glowUpCoach.item.skinQuality" = "Kualitas Kulit";
"analysis.glowUpCoach.item.skinQualityAssessment" = "Penilaian: Kualitas kulit Anda adalah salah satu bagian terkuat dari pemindaian ini, dengan warna yang bersih dan sedikit masalah tekstur yang terlihat.";
"analysis.glowUpCoach.item.skinQualityAction" = "Rencana: Tetap lindungi keunggulan tersebut dengan tabir surya harian, hidrasi, dan tidur yang konsisten.";
"analysis.glowUpCoach.item.harmony" = "Harmoni";
"analysis.glowUpCoach.item.harmonyAssessment" = "Penilaian: Keseimbangan wajah Anda secara keseluruhan stabil, yang membuat pemindaian terasa koheren daripada ditarik ke satu fitur.";
"analysis.glowUpCoach.item.harmonyAction" = "Rencana: Jaga kamera tetap lurus dan gunakan gaya sederhana agar keseimbangan alami ini tetap menjadi sinyal utama.";
"analysis.glowUpCoach.item.eyeAreaStrengthAssessment" = "Penilaian: Area mata memberikan kesan tenang, bersih, dan membantu wajah terasa mudah didekati.";
"analysis.glowUpCoach.item.eyeAreaStrengthAction" = "Rencana: Gunakan cahaya yang lebih lembut dan hindari bayangan tebal pada mata untuk menjaga fitur ini tetap jelas.";
