"analysis.photoOptimization.metric.frontReadDetail" = "تتحقق القراءة الأمامية من مدى توازن الوجه في اللقطة المباشرة التي تواجه الكاميرا. تعد القراءة الأمامية الثابتة مفيدة لصور الملف الشخصي الواضحة والمحاصيل ذات نمط الهوية. أبقِ الهاتف مستقيمًا وتجنب إمالة العدسة التي تمد الجزء السفلي من الوجه.";
"analysis.photoOptimization.metric.leftRead" = "القراءة من الجانب الأيسر";
