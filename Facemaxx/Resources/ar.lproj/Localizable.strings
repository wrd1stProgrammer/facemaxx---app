"analysis.photoOptimization.metric.retakePlanDetail" = "تعمل خطة الإعادة على تحويل التحليل إلى لقطة تالية قابلة للتكرار. استخدم ضوءًا أماميًا ناعمًا، وأمسك الكاميرا أعلى مستوى العين مباشرةً، والتقط إطارات متعددة مع دوران صغير للرأس. اختر النسخة التي يتم فيها قراءة العيون وخط الفك والتعبير بشكل واضح.";
"analysis.photoOptimization.metric.mainPhotoSuitability" = "ملاءمة الصورة الرئيسية";
"analysis.photoOptimization.metric.mainPhotoSuitabilityValue" = "7.2 · نسخة احتياطية جيدة";
"analysis.photoOptimization.metric.mainPhotoSuitabilityDetail" = "يقيس هذا ما إذا كانت الصورة يمكن أن تعمل كأول صورة لتطبيق المواعدة. تحتاج الصورة الرئيسية إلى الوضوح والدفء والشخصية الكافية لإيقاف التمرير السريع. إذا كان الوجه واضحًا ولكن الطاقة هادئة، فاستخدمها كنسخة احتياطية أو إعادة التقاط بحضور أكبر.";
"analysis.photoOptimization.metric.approachability" = "سهولة الوصول";
