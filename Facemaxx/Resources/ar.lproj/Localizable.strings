"analysis.photoOptimization.metric.avoidAngleDetail" = "يؤدي هذا إلى وضع علامة على المنظور الذي من المرجح أن يؤدي إلى إضعاف الصورة. يمكن للزوايا القريبة المنخفضة أن تزيد من حجم الجزء السفلي من الوجه، وتسطح العينين، وتجعل المحصول يبدو غير رسمي. تراجع للخلف، واستخدم التكبير الخفيف إذا كان متاحًا، وحافظ على استقامة العدسة.";
"analysis.photoOptimization.metric.retakePlan" = "خطة إعادة التشغيل";
