"analysis.photoOptimization.metric.editCleanupDetail" = "تركز عملية تنظيف التحرير على التصحيحات الصغيرة التي تجعل الصورة تبدو مقصودة. يمكن أن يؤدي التمويه المعتدل في الخلفية، أو الاقتصاص بشكل أكثر إحكامًا، أو تعديل التعرض إلى تحسين التركيز دون جعل الصورة تبدو وكأنها تم تحريرها بشكل زائد. حافظ على ملمس الوجه طبيعيًا.";
"analysis.photoOptimization.metric.bestAngle" = "أفضل زاوية";
