"analysis.photoOptimization.metric.approachabilityDetail" = "تقيس مدى سهولة التعامل مع الصورة ما إذا كان من السهل التفاعل معها. العيون الناعمة والوضعية المريحة والابتسامة اللطيفة يمكن أن تغير القراءة بسرعة. تجنب التعبيرات التي تبدو فارغة أو متوترة أو مبالغ فيها.";
"analysis.photoOptimization.metric.confidenceSignal" = "إشارة الثقة";
