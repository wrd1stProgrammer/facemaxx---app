"analysis.photoOptimization.metric.photoMix" = "مزيج الصور";
"analysis.photoOptimization.metric.photoMixValue" = "أضف السياق والتنوع";
"analysis.photoOptimization.metric.photoMixDetail" = "يلقي مزيج الصور نظرة على ما يجب أن تفعله هذه الصورة داخل مجموعة ملفات تعريف أوسع. تشتمل المجموعة القوية عادةً على صورة وجه واضحة واحدة، ولقطة واحدة لكامل الجسم أو لقطة أنيقة، وصورة اجتماعية أو نشاط واحد. يجب أن تملأ هذه الصورة الدور الذي تتعامل معه بشكل أفضل بدلاً من محاولة القيام بكل شيء.";
"analysis.photoOptimization.metric.avoidProfile" = "خطأ في الملف الشخصي يجب تجنبه";
"analysis.photoOptimization.metric.avoidProfileValue" = "لا تستخدم الرصاص بطاقة منخفضة";
"analysis.photoOptimization.metric.avoidProfileDetail" = "يؤدي هذا إلى وضع علامة على اختيار الملف الشخصي الذي من المرجح أن يؤدي إلى نتائج أقل. تجنب البدء بصورة قاتمة أو مسطحة أو مقصوصة بشكل مفرط أو مغلقة عاطفيًا. يجب أن تجعل الصورة الأولى الوجه والحيوية واضحة خلال ثانية واحدة.";
"analysis.photoOptimization.metric.profileCrop" = "قص الملف الشخصي";
