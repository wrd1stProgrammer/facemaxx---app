APP_ENV=local
API_PREFIX=/v1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Supabase
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=face-photos
SUPABASE_STORAGE_REQUIRED=false

# Image storage: auto, local, supabase, cloudinary.
# In auto mode, Cloudinary is used first when configured.
# Cloudinary
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

IMAGE_STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_FOLDER=facemaxx

# Local development only. Set false before production.
AUTH_DISABLED=true
DEMO_USER_ID=00000000-0000-0000-0000-000000000001

# AI provider: dummy, gemini, openai
AI_PROVIDER=dummy

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_FALLBACK_MODELS=gemini-3-flash-preview,gemini-3.1-flash-lite,gemini-2.5-flash-lite
GEMINI_RETRY_ATTEMPTS=1
GEMINI_RETRY_BASE_DELAY_SECONDS=0.8

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# RevenueCat
# Server-side secret key, not the iOS public SDK key.
REVENUECAT_SECRET_API_KEY=
# Optional bearer token configured in the RevenueCat webhook Authorization header.
REVENUECAT_WEBHOOK_BEARER_TOKEN=
